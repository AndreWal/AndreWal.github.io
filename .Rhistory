library(ggplot2)
library(readstata13)
library(cowplot)
library(openxlsx)
# Data
rm(list=ls())
dat<- read.dta13("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/final_dat_LA.dta")
coef <- read.xlsx("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/coef.xlsx")
vcov <- read.xlsx("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/vcov.xlsx")
rownames(vcov) <- vcov$X
vcov <- vcov[c(-1)]
modherf <- seq(min(dat$herf, na.rm = T),max(dat$herf, na.rm = T),.01)
modpop <- seq(min(dat$popdens1000, na.rm = T),max(dat$popdens1000, na.rm = T),.01)
# Marginal Effect Size
sigcoef <- coef$herf+coef$inter*modpop
parcoef <- coef$popdens+coef$inter*modherf
# SE/CIs using the Delta Method
sigvar <- vcov["herf","herf"] + (modpop^2)*vcov["inter", "inter"] + 2*modpop*vcov["herf", "inter"]
sigse = sqrt(sigvar)
z_score = qnorm(1 - ((1 - .95)/2))
sig_upp = sigcoef + z_score*sigse
sig_low = sigcoef - z_score*sigse
parvar <- vcov["popdens","popdens"] + (modherf^2)*vcov["inter", "inter"] + 2*modherf*vcov["popdens", "inter"]
parse = sqrt(parvar)
par_upp = parcoef + z_score*parse
par_low = parcoef - z_score*parse
sigeff <- data.frame(sigcoef,sig_upp,sig_low, modpop)
pareff <- data.frame(parcoef, par_upp,par_low, modherf)
ggplot(data = sigeff)+geom_point(aes(x=modpop, y=sigcoef))+theme_bw()+
geom_errorbar(aes(ymin = sig_low, ymax = sig_upp,x=modpop), width = .2,position=position_dodge(0.05))+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Effect of Initiatives on Social Expenditure", x = "",
y = "Marginal Effect of Initiatives")+ geom_hline(yintercept = 0, size = 0.2)
library(ggplot2)
library(readstata13)
library(cowplot)
library(openxlsx)
# Data
rm(list=ls())
dat<- read.dta13("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/final_dat_LA.dta")
coef <- read.xlsx("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/coef.xlsx")
vcov <- read.xlsx("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/vcov.xlsx")
rownames(vcov) <- vcov$X
vcov <- vcov[c(-1)]
modherf <- seq(min(dat$herf, na.rm = T),max(dat$herf, na.rm = T),.01)
modpop <- seq(min(dat$popdens1000, na.rm = T),max(dat$popdens1000, na.rm = T),.01)
# Marginal Effect Size
sigcoef <- coef$herf+coef$inter*modpop
parcoef <- coef$popdens+coef$inter*modherf
# SE/CIs using the Delta Method
sigvar <- vcov["herf","herf"] + (modpop^2)*vcov["inter", "inter"] + 2*modpop*vcov["herf", "inter"]
sigse = sqrt(sigvar)
z_score = qnorm(1 - ((1 - .95)/2))
sig_upp = sigcoef + z_score*sigse
sig_low = sigcoef - z_score*sigse
parvar <- vcov["popdens","popdens"] + (modherf^2)*vcov["inter", "inter"] + 2*modherf*vcov["popdens", "inter"]
parse = sqrt(parvar)
par_upp = parcoef + z_score*parse
par_low = parcoef - z_score*parse
sigeff <- data.frame(sigcoef,sig_upp,sig_low, modpop)
pareff <- data.frame(parcoef, par_upp,par_low, modherf)
# ME Plot
inime <-   ggplot(data = sigeff)+geom_point(aes(x=modpop, y=sigcoef))+theme_bw()+
geom_errorbar(aes(ymin = sig_low, ymax = sig_upp,x=modpop), width = .2,position=position_dodge(0.05))+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Effect of Initiatives on Social Expenditure", x = "",
y = "Marginal Effect of Initiatives")+ geom_hline(yintercept = 0, size = 0.2)
histdia1 <- ggplot(data=dat, aes(dat$popdens1000)) +
geom_histogram() + labs(x="Number of Parties in Government", y="Count")
plot <- plot_grid(inime,histdia1, nrow = 2, align = "v", rel_heights = c(3, 1))
ggsave("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/herf.eps", height=7, width=10, units='in',device=cairo_ps)
ggsave("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Estimation/herf.eps", height=7, width=10, units='in',device=cairo_ps)
ggplot(data = sigeff)+geom_point(aes(x=modpop, y=sigcoef))+theme_bw()+
geom_errorbar(aes(ymin = sig_low, ymax = sig_upp,x=modpop),alpha=0.3, width=0.0, size=1, color="black")+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Effect of Government Fractionalization on Direct Taxation", x = "",
y = "Marginal Effect of Fractionalization")+ geom_hline(yintercept = 0, size = 0.2)
inime <-   ggplot(data = sigeff)+geom_point(aes(x=modpop, y=sigcoef))+theme_bw()+
geom_errorbar(aes(ymin = sig_low, ymax = sig_upp,x=modpop),alpha=0.3, width=0.0, size=1, color="black")+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Effect of Government Fractionalization on Direct Taxation", x = "",
y = "Marginal Effect of Fractionalization")+ geom_hline(yintercept = 0, size = 0.2)
histdia1 <- ggplot(data=dat, aes(dat$popdens1000)) +
geom_histogram() + labs(x="Population Density", y="Count")
plot <- plot_grid(inime,histdia1, nrow = 2, align = "v", rel_heights = c(3, 1))
ggsave("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Estimation/herf.eps", height=7, width=10, units='in',device=cairo_ps)
ggplot(data = pareff)+geom_point(aes(x=modherf, y=parcoef))+theme_bw()+
geom_errorbar(aes(ymin = par_low, ymax = par_upp,x=modherf),alpha=0.3, width=0.0, size=1, color="black")+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Effect of Government Fractionalization on Direct Taxation", x = "",
y = "Marginal Effect of Fractionalization")+ geom_hline(yintercept = 0, size = 0.2)
inime <-   ggplot(data = pareff)+geom_point(aes(x=modherf, y=parcoef))+theme_bw()+
geom_errorbar(aes(ymin = par_low, ymax = par_upp,x=modherf),alpha=0.3, width=0.0, size=1, color="black")+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Effect of Population Density on Direct Taxation", x = "",
y = "Marginal Effect of Population Density")+ geom_hline(yintercept = 0, size = 0.2)
histdia1 <- ggplot(data=dat, aes(dat$herf)) +
geom_histogram() + labs(x="Government Fractionalization", y="Count")
plot <- plot_grid(inime,histdia1, nrow = 2, align = "v", rel_heights = c(3, 1))
