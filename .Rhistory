sw <- sw%>%
separate(Endorsed_by_other_Party, c("Party1","Party2","Party3","Party4","Party5"), "#")
count_na <- function(x) sum(!is.na(x))
sw$diffparsup <- apply(sw[,c("Party1","Party2","Party3","Party4","Party5")], 1, count_na)
test <- sw[c("Country","Electoral_District_Number","Year2","by_elect","Party","Party1","Party2","Party3","Party4","Party5")]
test <- melt(test, id.vars = c("Country","Electoral_District_Number","Year2","by_elect"))
test <- test %>% filter(!is.na(value)) %>% group_by(Country,Electoral_District_Number,Year2, by_elect) %>%
summarize(diffpar= n_distinct(value))
sw <- merge(sw,test, by = c("Country","Electoral_District_Number","Year2","by_elect"))
sw$compsup <- sw$diffparsup/sw$diffpar
sw <- sw %>%
arrange(Country,Electoral_District_Number,Year2, Round_of_Voting,by_elect,desc(Vote_share)) %>%
group_by(Country,Electoral_District_Number,Year2, Round_of_Voting,by_elect) %>% mutate(compsup1 = nth(compsup,1,default = 0),
compsup2 = nth(compsup,2,default = 0),
compsup3 = nth(compsup,3,default = 0),
compsup4 = nth(compsup,4,default = 0),
compsup5 = nth(compsup,5,default = 0),
compsup6 = nth(compsup,6,default = 0),
compsup7 = nth(compsup,7,default = 0),
compsup8 = nth(compsup,8,default = 0),
compsup9 = nth(compsup,9,default = 0),
compsup10 = nth(compsup,10,default = 0))
sw$compsupN <- ifelse(sw$Number_available_seats==1, sw$compsup1,
ifelse(sw$Number_available_seats==2, sw$compsup2,
ifelse(sw$Number_available_seats==3, sw$compsup3,
ifelse(sw$Number_available_seats==4, sw$compsup4,
ifelse(sw$Number_available_seats==5, sw$compsup5,
ifelse(sw$Number_available_seats==6, sw$compsup6,
ifelse(sw$Number_available_seats==7, sw$compsup7,
ifelse(sw$Number_available_seats==8, sw$compsup8,
ifelse(sw$Number_available_seats==9, sw$compsup9,0)))))))))
sw$conc <- apply(sw[,c(27:36)],1,function(x)(sum(x^2)))
# Aggregate to district level
test <- sw %>% group_by(Year, Electoral_District_Number, Round_of_Voting,by_elect,Party) %>%
summarise(votes = sum(Votes_Received), seats = sum(Elected), Turn = max(Turnout),
dismag = max(Number_available_seats),compsupN=max(compsupN),can = n(),conc = max(conc))
test <- test %>% filter(Round_of_Voting==1 & by_elect ==0)
test$disq <- ((test$seats/test$dismag-test$votes/test$Turn)^2)/(test$votes/test$Turn)
test$disq2 <- (test$votes/test$Turn-test$seats/test$dismag)^2
test <- test %>% group_by(Year, Electoral_District_Number, Round_of_Voting,by_elect) %>%
summarise(dispro =sum(disq) ,dispro2 = sum(disq2), dismag = max(dismag),compsupN =max(compsupN),can = sum(can),conc = max(conc))
test <- test %>% arrange(Electoral_District_Number,Year) %>% group_by(Electoral_District_Number) %>%
mutate(ldispro = lag(dispro), ldispro2 = lag(dispro2))
test$comp <- test$can-test$dismag
test$dispro2 <- sqrt(0.5*test$dispro2)
test$compsupbin <- ifelse(test$compsupN>0,1,0)
plot(test$dismag,test$dispro)
m1 <- lm(dispro2~factor(Year)+factor(Electoral_District_Number)+dismag*compsupN, test)
coeftest(m1,cluster.vcov(m1, cbind(test$Electoral_District_Number,test$Year)))
m1 <- lm(dispro~factor(Year)+factor(Electoral_District_Number)+dismag*compsupN, test)
coeftest(m1,cluster.vcov(m1, cbind(test$Electoral_District_Number,test$Year)))
cova <- cluster.vcov(m1, cbind(test$Electoral_District_Number,test$Year))
pareff <- interaction_plot_continuous(m1, effect = "compsupN", moderator = "dismag",
interaction = "dismag:compsupN", varcov = cova)
source("D:/Sync/Dropbox/PhD/Statistics learning/Scripts/Interaction/interaction_plot.R")
cova <- cluster.vcov(m1, cbind(test$Electoral_District_Number,test$Year))
pareff <- interaction_plot_continuous(m1, effect = "compsupN", moderator = "dismag",
interaction = "dismag:compsupN", varcov = cova)
m1 <- lm(dispro~Year*factor(Electoral_District_Number)+dismag*compsupN, test)
coeftest(m1,cluster.vcov(m1, cbind(test$Electoral_District_Number,test$Year)))
m1 <- lm(dispro~factor(Year)+factor(Electoral_District_Number)+dismag+compsupN, test)
coeftest(m1,cluster.vcov(m1, cbind(test$Electoral_District_Number,test$Year)))
m1 <- lm(dispro~factor(Year)+factor(Electoral_District_Number)+dismag+poly(compsupN,2,raw = T), test)
coeftest(m1,cluster.vcov(m1, cbind(test$Electoral_District_Number,test$Year)))
test <- test %>% filter(comp>0)
m1 <- lm(dispro~factor(Year)+factor(Electoral_District_Number)+dismag+poly(compsupN,2,raw = T), test)
coeftest(m1,cluster.vcov(m1, cbind(test$Electoral_District_Number,test$Year)))
m1 <- lm(dispro~factor(Year)+dismag+poly(compsupN,2,raw = T), test)
coeftest(m1,cluster.vcov(m1, cbind(test$Electoral_District_Number,test$Year)))
m1 <- lm(dispro~factor(Year)+factor(Electoral_District_Number)+dismag+poly(compsupN,2,raw = T), test)
coeftest(m1,cluster.vcov(m1, cbind(test$Electoral_District_Number,test$Year)))
