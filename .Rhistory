## Concordat different Reforms
cova <- vcovBK(est9, cluster = "time")
konkeff23 <- interaction_plot_continuous(est9, effect = "factor(konkalt)2", moderator = "konkmiou", interaction = "factor(konkalt)2:konkmiou", varcov = cova)
konkeff23$effect <- ((exp(konkeff23$delta_1)-1)*100)
konkeff37 <- interaction_plot_continuous(est9, effect = "factor(konkalt)3", moderator = "konkmiou", interaction = "factor(konkalt)3:konkmiou", varcov = cova)
konkeff37$effect <- ((exp(konkeff37$delta_1)-1)*100)
konkeff59 <- interaction_plot_continuous(est9, effect = "factor(konkalt)4", moderator = "konkmiou", interaction = "factor(konkalt)4:konkmiou", varcov = cova)
konkeff59$effect <- ((exp(konkeff59$delta_1)-1)*100)
rug <- model.frame(est9)
rug$`as.factor(year)` <- as.numeric(rug$`as.factor(year)`)
rug$konkalt <- as.numeric(levels(rug$`factor(konkalt)`))[rug$`factor(konkalt)`]
rug23 <- subset(rug, rug$`as.factor(year)` < 8)
rug37 <- subset(rug, rug$`as.factor(year)` > 8 & rug$`as.factor(year)` <30)
rug59 <- subset(rug, rug$`as.factor(year)` > 29)
konkme <- ggplot(data = konkeff23)+geom_line(aes(x=x_2, y=delta_1))+theme_bw()+geom_line(aes(x=x_2, y=lower_bound), color = "grey")+
geom_line(aes(x=x_2, y=upper_bound), color = "grey")+
geom_line(data = konkeff37, aes(x=x_2, y=delta_1))+theme_bw()+geom_line(data = konkeff37, aes(x=x_2, y=lower_bound), color = "grey")+
geom_line(data = konkeff37, aes(x=x_2, y=upper_bound), color = "grey")+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Effect of Concordat on Social Expenditure",
x = "% Outward Migration",
