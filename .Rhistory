summary(RDestimate(diffnonsocsup~socmarg | Year3+id, data = runoff, cluster = c(runoff$Electoral_District_Number)))
summary(RDestimate(diffnonsocsup~socmarg | minIIround+lnonsocsup+lcomp+marg+I(marg^2)+Year3+id, data = runoff, cluster = c(runoff$Electoral_District_Number)))
