model2 <- as.formula(logPCexp_r~ldef+lsigperpop20_gini+lnumpar*lfedrev)
est2 <- plm(model2, dat, index = c("cod","year"),  effect = "twoways")
cov2 <- c*vcovBK(est2)
coeftest(est2, c*vcovBK(est2))
coeftest(est2, c*vcovHC(est2, cluster = c("group")))
