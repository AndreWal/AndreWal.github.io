m1 <- lm(loss~Dom_Pos, test3)
m3 <- lm(loss~nthres2, test3)
rcoef[[i]] <- c(m1$coefficients[2],sqrt(diag(vcov(m1)))[2],m3$coefficients[2],sqrt(diag(vcov(m3)))[2], (i+3))
}
regres <- do.call(rbind.data.frame, rcoef)
colnames(regres) <- c("domest","domse","nthest","nthse","loss_GL")
