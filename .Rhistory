library(lmtest)
library(plm)
library(dplyr)
library(ggplot2)
rm(list=ls())
load("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/analysis_data.RData")
set <- seq(1830, 1930, 5)
datwint <- subset(findat, year %in% set)
# Trend again!
datwint <- datwint %>% arrange(canton,year) %>% group_by(canton) %>%
mutate(ldir_sh5 = lag(dir_sh), ldir_pc5 = lag(dir_pc), ddir_pc5 = dir_pc-ldir_pc5, lddir_pc5 = lag(ddir_pc5))
# Estimations, try substituting numpar with maj/herf
test <- plm(dir_pc~ldir_pc5+fed_sh+def_sh+ineqcow+muni+popdens*herf+suffoek+hddi, data = datwint, index = c("canton","year"), model = "pooling")
coeftest(test, vcovHC(test, method= "arellano", type="HC3"))
test <- plm(dir_pc~factor(canton)+ldir_pc5+fed_sh+def_sh+ineqcow+muni+popdens*herf+suffoek+hddi, data = datwint, index = c("canton","year"), model = "pooling")
coeftest(test, vcovHC(test, method= "arellano", type="HC3"))
