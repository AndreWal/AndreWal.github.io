names(fints)[names(fints)=="Jahr"] <- "year"
# Number of Parties
fints[2:16] <- round(apply(fints[2:16],2, function(x) x/fints$Seat),2)
fints$numpar <- rowSums(fints[c(2:11,13:16)] != 0)
fints$numpar <- ifelse(fints$year >1995 & fints$year <1999 & fints$Code == "TI", fints$numpar+1,fints$numpar)
numdat <- subset(fints, Code != "AI" &   Code != "JU")
numdat <- subset(numdat, year>1893)
dat <- numdat[c("numpar","year")]
year <- unique(dat$year)
dat$par1 <- ifelse(dat$numpar == 1,1,0)
dat$par2 <- ifelse(dat$numpar == 2,1,0)
dat$par3 <- ifelse(dat$numpar == 3,1,0)
dat$par4 <- ifelse(dat$numpar == 4,1,0)
dat$par5 <- ifelse(dat$numpar == 5,1,0)
par1 <- tapply(dat$par1, dat$year, sum, na.rm = T)
par2 <- tapply(dat$par2, dat$year, sum, na.rm = T)
par3 <- tapply(dat$par3, dat$year, sum, na.rm = T)
par4 <- tapply(dat$par4, dat$year, sum, na.rm = T)
par5 <- tapply(dat$par5, dat$year, sum, na.rm = T)
newdat <- data.frame(year,par1,par2,par3,par4,par5)
newdat2 <- newdat %>% gather(party, count, -year)
ggplot(data = newdat2, aes(x=year,y=count))+geom_line(aes(group = party,linetype = party))+
geom_point(data=newdat2[seq(1, nrow(newdat2), 8),] ,aes(shape=party) ,size = 3)+ theme_bw()+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(x = "Year",y = "Number of Cantons")
ggsave("D:/Sync/Dropbox/Papers/Canton_Exec_Data/Paper/numpar.eps", height=7, width=10, units='in',device=cairo_ps)
### Government Volatility
# 1894-2017
finbin <- fints
for (i in c(2:11,13:16)){
finbin[,i] <- ifelse(finbin[,i] >0, colnames(finbin)[i],0)
}
finbin$coal <- do.call(paste0, finbin[c(2:11,13:16)])
finbin2 <- subset(finbin, Code != "AI" &   Code != "JU" & year>1893)
finbin2 <- finbin2 %>%  group_by(Code) %>% mutate(govol = ifelse(coal != lag(coal), 1, 0))
finfinal <- finbin2 %>%  group_by(year) %>% summarize(count=sum(govol))
ggplot(data = finfinal, aes(x = year, y = count))+stat_smooth(se = T,color="black")+theme_bw()+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank(),legend.text=element_text(size=14))+labs(x = "Year",
y = "Change in Party Composition")
