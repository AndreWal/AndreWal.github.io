library(effects)
library(multiwayvcov)
library(lmtest)
library(brglm2)
library(ggplot2)
library(texreg)
library(dummies)
rm(list=ls())
load("D:/Sync/Dropbox/Papers/PreColonial_States/Data/findat.RData")
stat$cont <- as.factor(stat$cont)
dum <- dummy(stat$cont)
stat <- cbind(stat, dum)
stat$Country <- as.factor(stat$Country)
stat$Interval <- as.factor(stat$Interval)
# Estimation
m1 <- glm(staevent~time+time2+time3+fordom, stat, family = binomial(link='logit'), method = "brglmFit")
ct1 <- coeftest(m1, cluster.vcov(m1, cbind(stat$Country.code)))
m1se <- ct1[, 2]
m1pval <- ct1[, 4]
class(m1) <- c("glm","lm")
m1$call[1] <- quote(lm())
m2 <- glm(staevent~time+time2+time3+chief+fordom+presta+splag2, stat, family = binomial(link='logit'), method = "brglmFit")
ct2 <- coeftest(m2, cluster.vcov(m2, cbind(stat$Country.code)))
m2se <- ct2[, 2]
m2pval <- ct2[, 4]
class(m2) <- c("glm","lm")
m2$call[1] <- quote(lm())
m3 <- glm(staevent~time+time2+time3+chief+fordom+presta+splag2+agritr, stat, family = binomial(link='logit'), method = "brglmFit")
ct3 <- coeftest(m3, cluster.vcov(m3, cbind(stat$Country.code)))
m3se <- ct3[, 2]
m3pval <- ct3[, 4]
class(m3) <- c("glm","lm")
m3$call[1] <- quote(lm())
m4 <- glm(staevent~time+time2+time3+chief+fordom+presta+splag2+contAmericas+contAsia+contEurope+contOceania, stat, family = binomial(link='logit'), method = "brglmFit")
ct4 <- coeftest(m4, cluster.vcov(m4, cbind(stat$Country.code)))
m4se <- ct4[, 2]
m4pval <- ct4[, 4]
class(m4) <- c("glm","lm")
m4$call[1] <- quote(lm())
m5 <- glm(staevent~time+time2+time3+chief+fordom+presta+splag2+agritr+contAmericas+contAsia+contEurope+contOceania, stat, family = binomial(link='logit'), method = "brglmFit")
ct5 <- coeftest(m5, cluster.vcov(m5, cbind(stat$Country.code)))
m5se <- ct5[, 2]
m5pval <- ct5[, 4]
class(m5) <- c("glm","lm")
m5$call[1] <- quote(lm())
texreg(list(m1,m2,m3,m4,m5),table = T, file = "D:/Sync/Dropbox/Papers/PreColonial_States/Paper/reg.tex",
stars = c(0.05, 0.01, 0.001), booktabs = T, dcolumn = T, use.packages = F,
override.se = list(m1se,m2se,m3se,m4se,m5se), override.pvalues = list(m1pval,m2pval,m3pval,m4pval,m5pval),
custom.note = c("Cluster-Robust Standard Errors by Country. $^{*}$p$<$0.05; $^{**}$p$<$0.01.; $^{***}$p$<$0.001."),
scalebox = .75,
caption = "External Domination, Endogenous Political Development and the Agricultural Transition", label = "est1",
custom.coef.map = list("fordom" = "External Domination","chief" = "Chiefdom","presta" = "Historical Predecessors","splag2" = "Diffusion",
"agritr" = "Agricultural Transition","contAmericas" = "Americas","contAsia" = "Asia",
"contEurope" = "Europe", "contOceania" = "Oceania", "time" = "Time", "time2" = "Time squared",
"time3" = "Time cubed"))
# Predicted probabilities
cluster.ids.h <- data.frame(i = stat$Country.code)
mwfunch <- function(x,cluster) {return(cluster.vcov(x, cluster= cluster.ids.h))}
plotf <- as.data.frame(effect("agritr", m5, vcov=mwfunch,xlevels=list(c(0,1)),typical = mean))
plotf <- subset(plotf, plotf$agritr %in% c(0,1))
ggplot(data=plotf, aes(x=agritr, y=fit))  +geom_point()+
geom_errorbar(aes(ymin=lower,ymax=upper),alpha=0.3, width=0.2, size=1, color="black")+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+theme_bw()+ labs(title = "Predicted Probabilities for Agricultural Transition",x = "Agricultural Transition", y="Predicted Probability")
ggsave("D:/Sync/Dropbox/Papers/PreColonial_States/Paper/agri.eps", height=7, width=10, units='in',device=cairo_ps)
plotf <- as.data.frame(effect("fordom", m5, vcov=mwfunch,xlevels=list(c(0,1)),typical = mean))
plotf <- subset(plotf, plotf$fordom %in% c(0,1))
ggplot(data=plotf, aes(x=fordom, y=fit))  + geom_point()+
geom_errorbar(aes(ymin=lower,ymax=upper),alpha=0.3, width=0.2, size=1, color="black")+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+theme_bw()+
labs(title = "Predicted Probabilities for Foreign Domination",x = "Foreign Domination", y="Predicted Probability")
ggsave("D:/Sync/Dropbox/Papers/PreColonial_States/Paper/fordom.eps", height=7, width=10, units='in',device=cairo_ps)
plotf <- as.data.frame(effect("chief", m5, vcov=mwfunch,xlevels=list(c(0,1)),typical = mean))
plotf <- subset(plotf, plotf$chief %in% c(0,1))
ggplot(data=plotf, aes(x=chief, y=fit))  + geom_point()+
geom_errorbar(aes(ymin=lower,ymax=upper),alpha=0.3, width=0.2, size=1, color="black")+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+theme_bw()+
labs(title = "Predicted Probabilities for Chiefdoms",x = "Chiefdom", y="Predicted Probability")
ggsave("D:/Sync/Dropbox/Papers/PreColonial_States/Paper/chief.eps", height=7, width=10, units='in',device=cairo_ps)
