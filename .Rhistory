library(ggplot2)
library(readstata13)
# Data
rm(list=ls())
dat<- read.dta13("D:/Sync/Dropbox/Papers/Cantons_Poor_Law/data/final.dta")
dat <- subset(dat, year >1929 & year <2001)
dat$sigperpop20_gini <-  dat$sigperpop20_gini*100
coef <- read.csv2("D:/Sync/Dropbox/Papers/Cantons_Poor_Law/do_files/coef.csv")
vcov <- read.csv2("D:/Sync/Dropbox/Papers/Cantons_Poor_Law/do_files/vcov.csv")
rownames(vcov) <- vcov$X
vcov <- vcov[c(-1)]
# Range of the Moderator
modpar <- seq(1,5,1)
modsig <- seq(-17,0,0.01)
# Marginal Effect Size
sigcoef <- coef$init+coef$inter*modpar
parcoef <- coef$numpar+coef$inter*modsig
# SE/CIs using the Delta Method
sigvar <- vcov["init","init"] + (modpar^2)*vcov["inter", "inter"] + 2*modpar*vcov["init", "inter"]
sigse = sqrt(sigvar)
z_score = qnorm(1 - ((1 - .95)/2))
sig_upp = sigcoef + z_score*sigse
sig_low = sigcoef - z_score*sigse
parvar <- vcov["numpar","numpar"] + (modsig^2)*vcov["inter", "inter"] + 2*modsig*vcov["numpar", "inter"]
parse = sqrt(parvar)
par_upp = parcoef + z_score*parse
par_low = parcoef - z_score*parse
sigeff <- data.frame(sigcoef,sig_upp,sig_low, modpar)
pareff <- data.frame(parcoef, par_upp,par_low, modsig)
# ME Plot
inime <- ggplot(data = sigeff)+geom_point(aes(x=modpar, y=sigcoef))+theme_bw()+
geom_errorbar(aes(ymin = sig_low, ymax = sig_upp,x=modpar), width = .2,position=position_dodge(0.05))+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Effect of Initiatives on Social Expenditure", x = "",
y = "Marginal Effect of Initiatives")+ geom_hline(yintercept = 0, size = 0.2)
parme <- ggplot(data = pareff)+geom_line(aes(x=modsig, y=parcoef))+theme_bw()+geom_line(aes(x=modsig, y=par_low), color = "grey")+
geom_line(aes(x=modsig, y=par_upp), color = "grey")+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Effect of Number of Parties on Social Expenditure",
x = "",y = "Marginal Effect of Parties")+
geom_hline(yintercept = 0, size = 0.2)+  geom_rug(data = dat, aes(x = sigperpop20_gini))
library(ggplot2)
library(readstata13)
# Data
rm(list=ls())
dat<- read.dta13("D:/Sync/Dropbox/Papers/Cantons_Poor_Law/data/final.dta")
dat <- subset(dat, year >1929 & year <2001)
dat$sigperpop20_gini <-  dat$sigperpop20_gini*100
coef <- read.csv2("D:/Sync/Dropbox/Papers/Cantons_Poor_Law/do_files/coef.csv")
vcov <- read.csv2("D:/Sync/Dropbox/Papers/Cantons_Poor_Law/do_files/vcov.csv")
rownames(vcov) <- vcov$X
vcov <- vcov[c(-1)]
# Range of the Moderator
modpar <- seq(1,5,1)
modsig <- seq(-17,0,0.01)
# Marginal Effect Size
sigcoef <- coef$init+coef$inter*modpar
parcoef <- coef$numpar+coef$inter*modsig
# SE/CIs using the Delta Method
sigvar <- vcov["init","init"] + (modpar^2)*vcov["inter", "inter"] + 2*modpar*vcov["init", "inter"]
sigse = sqrt(sigvar)
z_score = qnorm(1 - ((1 - .95)/2))
sig_upp = sigcoef + z_score*sigse
sig_low = sigcoef - z_score*sigse
parvar <- vcov["numpar","numpar"] + (modsig^2)*vcov["inter", "inter"] + 2*modsig*vcov["numpar", "inter"]
parse = sqrt(parvar)
par_upp = parcoef + z_score*parse
par_low = parcoef - z_score*parse
sigeff <- data.frame(sigcoef,sig_upp,sig_low, modpar)
pareff <- data.frame(parcoef, par_upp,par_low, modsig)
# ME Plot
inime <- ggplot(data = sigeff)+geom_point(aes(x=modpar, y=sigcoef))+theme_bw()+
geom_errorbar(aes(ymin = sig_low, ymax = sig_upp,x=modpar), width = .2,position=position_dodge(0.05))+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Effect of Initiatives on Social Expenditure", x = "",
y = "Marginal Effect of Initiatives")+ geom_hline(yintercept = 0, size = 0.2)
parme <- ggplot(data = pareff)+geom_line(aes(x=modsig, y=parcoef))+theme_bw()+geom_line(aes(x=modsig, y=par_low), color = "grey")+
geom_line(aes(x=modsig, y=par_upp), color = "grey")+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Effect of Number of Parties on Social Expenditure",
x = "",y = "Marginal Effect of Parties")+
geom_hline(yintercept = 0, size = 0.2)+  geom_rug(data = dat, aes(x = sigperpop20_gini))
# Analysis Socialist Threat
library(multiwayvcov)
library(lmtest)
library(texreg)
library(effects)
library(ggplot2)
library(survival)
library(brglm)
rm(list=ls())
load("D:/Sync/Dropbox/Papers/Soc_Threat/Data/socdat.RData")
socdat$code <- with(socdat, paste0(Country, Electoral_District_Number))
socdat$Country <- as.factor(socdat$Country)
socdat$id <- as.factor(socdat$id)
socdat$Round_of_Voting <- as.factor(socdat$Round_of_Voting)
socdat$fYear <- as.factor(socdat$Year)
socdat <- subset(socdat, compse!=0)
est1 <- brglm(Elected~Country+Year+incumb+sup+compse+Vote_share, data = socdat, family = binomial("logit"))
cov1 <- as.matrix(sqrt(diag(cluster.vcov(est1, cbind(socdat$Canton,socdat$Year)))))
rownames(cov1) <- (names(est1$coefficients))
coeftest(est1,cluster.vcov(est1, cbind(socdat$Canton,socdat$Year)))
est1 <- brglm(Elected~Country+Year+incumb+sup+compse+compsup*Vote_share, data = socdat, family = binomial("logit"))
cov1 <- as.matrix(sqrt(diag(cluster.vcov(est1, cbind(socdat$Canton,socdat$Year)))))
rownames(cov1) <- (names(est1$coefficients))
coeftest(est1,cluster.vcov(est1, cbind(socdat$Canton,socdat$Year)))
