# Test measurement error due to interpolation
meas <- subset(dat, year>1950)
meas <- meas[c("cod","year","logPCwelfare_r")]
testseq <- seq(1,25,4)
testseq
library(dplyr)
meas <-  meas %>% arrange(cod, year) %>% group_by(cod) %>%
mutate(miss = replace(logPCwelfare_r, !(row_number() %in% testseq), NA))%>%
mutate(welinter = na.approx(miss, maxgap = 2, rule = 2))
cor(meas$logPCwelfare_r,meas$welinter)
View(meas)
meas <- subset(dat, year>1950)
meas <- meas[c("cod","year","logPCwelfare_r")]
testseq <- seq(1,25,4)
library(dplyr)
meas <-  meas %>% arrange(cod, year) %>% group_by(cod) %>%
mutate(miss = replace(logPCwelfare_r, !(row_number() %in% testseq), NA))%>%
mutate(welinter = na.approx(miss, maxgap = 3, rule = 2))
cor(meas$logPCwelfare_r,meas$welinter)
View(meas)
