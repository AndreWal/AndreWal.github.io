### Concordat
library(readstata13)
library(spdep)
library(rgdal)
library(plm)
library(lmtest)
library(plyr)
library(stargazer)
library(ggplot2)
library(cowplot)
library(car)
rm(list=ls())
# Subset Data
dat3 <- read.dta13("D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Data/Hist/final.dta")
dat3 <- subset(dat3, dat3$year >1929 & dat3$year < 2001)
dat2 <- subset(dat3, dat3$year >1929 & dat3$year < 1976)
dat2$konkmiou <- dat2$konkmiou*100
dat2$konkmigin <- dat2$konkmigin*100
# Spatial Weights
map <- readOGR(dsn = "D:/Sync/Dropbox/Papers/Cantons_Poor_Law/data/Spatial_Data", layer = "Kantons_without_Jura")
levels(map@data$AK) <- c(levels(map@data$AK), "BE")
levels(map@data$Name) <- c(levels(map@data$Name), "Bern")
map@data$AK[map@data$AK %in% NA] <- "BE"
map@data$Name[map@data$Name %in% NA] <- "Bern"
test <- map@data
nbob1 <- poly2nb(map, row.names = map@data$AK)
nbob2 <- knn2nb(knearneigh(coordinates(map), k = 4))
wei1 <- nb2mat(nbob1,  style="minmax", zero.policy = T)
wei2 <- nb2mat(nbob1,  style="W", zero.policy = T)
colnames(wei1) <- row.names(wei1)
wei1 <- wei1[order(row.names(wei1)),order(colnames(wei1))]
# Create Spatial Lags
weisocex <- list()
for (i in 1:length(unique(dat2$year))){
i <- i+1929
datayr <- subset(dat2, dat2$year == i)
socexp <- datayr$logPCwelfare_r
datayr$spsoc <- wei1%*%socexp
datayr$spsoc2 <- wei2%*%socexp
weisocex[[i]] <- datayr
i <- i-1929
}
dat <- rbind.fill(weisocex)
dat2 <- pdata.frame(dat, index = c("cod","year"))
## Coefficient of Variation
yr <- list()
cvar <- list()
total <- list()
for (i in 1:length(unique(dat3$year))){
i <- i+1929
datyr <- subset(dat3, year==i)
cvar[[i]] <- sqrt(exp(var(datyr$logPCwelfare_r))-1)
yr[[i]] <- i
total[[i]] <- sum(exp(datyr$logPCwelfare_r))
i <- i+1929
}
covar <- data.frame(unlist(total),unlist(cvar),unlist(yr))
save.dta13(dat, "D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Data/Hist/final2.dta")
p1 <- ggplot(data = covar, aes(x=unlist.yr., y=unlist.total.))+geom_line(color = "black")+theme_bw()+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Social Spending of the Swiss Cantons 1930-2000",
x = "Year",
y = "Social Spending per capita")
p2 <- ggplot(data = covar, aes(x=unlist.yr., y=unlist.cvar.))+geom_line(color = "black")+theme_bw()+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Convergence of Social Spending of the Swiss Cantons 1930-2000",
x = "Year",
y = "Coefficient of Variation")
plot <- plot_grid(p1,p2, nrow = 2, align = "v")
ggsave("D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Paper/JOP_II_RR/devsoc.eps", height=7, width=10, units='in',device=cairo_ps)
# Unit Root Tests
summary(purtest(fdlogPCwelfare_r ~ trend, data = dat2, lags = "AIC", pmax = 3, test = "levinlin"))
summary(purtest(fdlogPCwelfare_r ~ trend, data = dat2, lags = "AIC", pmax = 3, test = "Pm"))
summary(purtest(fdlogPCwelfare_r ~ trend, data = dat2, lags = "AIC", pmax = 3, test = "invnormal"))
summary(purtest(fdlogPCwelfare_r ~ trend, data = dat2, lags = "AIC", pmax = 3, test = "logit"))
# Summary Statistics
sumdat <- dat[,c("logPCwelfare_r","konk","konkalt","konkmiou","konkmigin","infmort","depratio","empl2nd","perc_urban",
"log_pop2","logPCfedsubs_ptr","sigperpop20_gini","Mandbugref","dfs","dummy_prop","left","numpar","spsoc2")]
stargazer(sumdat, summary = T, title = "Summary Statistics", font.size = "small",
out = "D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Paper/JOP_II_RR/sumst.tex",
covariate.labels = c("ln Soc. Exp. p.c.","Concordat","Concordat Reforms","Outward Mig. Conc",
"Inward Mig. Conc.","Infant Mortality",
"$\\%$ Dependency Ratio","$\\%$ Industrial Labor Force","$\\%$ Urbanization","ln Population Size",
"ln Federal Subsidies","$\\%$ Sig. Initiative","Mand. Budget Ref.","Female Suffrage",
"PR Legislative","Left Parties","Num. Parties","Spatial Lag"))
# ECM
test <- plm(fdlogPCwelfare_r~logPCwelfare_r+konk*poly(konkmiou,3,raw=T)+konk*poly(konkmigin,3,raw=T)+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2, dat2, model = "within", effect ="time")
coeftest(test,vcovHC(test, cluster = c("group")))
test <- plm(fdlogPCwelfare_r~as.factor(year)+logPCwelfare_r+konk*konkmiou+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2, dat2, model = "pooling")
coeftest(test,vcovHC(test, cluster = c("group")))
test <- plm(fdlogPCwelfare_r~as.factor(year)+logPCwelfare_r+konk*konkmiou+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2, dat2, model = "pooling")
coeftest(test,vcovBK(test, cluster = c("time")))
test <- plm(fdlogPCwelfare_r~as.factor(year)+as.factor(cod)+logPCwelfare_r+konk*konkmiou+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2, dat2, model = "pooling")
coeftest(test,vcovBK(test, cluster = c("time")))
test <- plm(fdlogPCwelfare_r~as.factor(year)+as.factor(cod)*year+logPCwelfare_r+konk*konkmiou+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2, dat2, model = "pooling")
coeftest(test,vcovBK(test, cluster = c("time")))
test <- plm(fdlogPCwelfare_r~as.factor(cod)*year+logPCwelfare_r+konk*konkmiou+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2, dat2, model = "within",effect = "time")
coeftest(test,vcovBK(test, cluster = c("time")))
test <- plm(fdlogPCwelfare_r~as.factor(cod)*as.numeric(year)+logPCwelfare_r+konk*konkmiou+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2, dat2, model = "within",effect = "time")
coeftest(test,vcovBK(test, cluster = c("time")))
test <- plm(fdlogPCwelfare_r~as.factor(cod)*as.numeric(year)+logPCwelfare_r+factor(konkalt)*konkmiou+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2, dat2, model = "within",effect = "time")
coeftest(test,vcovBK(test, cluster = c("time")))
