require(readstata13)
require(plm)
require(DataCombine)
require(lmtest)
library(foreign)
library(multiwayvcov)
rm(list=ls())
dat <- read.dta13("D:/Sync/Dropbox/Papers/Cantons_Poor_Law/data/final.dta")
dat <- subset(dat, dat$year >1929)
dat$codnum <- as.numeric(dat$cod)
G <- length(unique(dat$cod))
c <- G/(G - 1)
pdat <- pdata.frame(dat, index = c("cod","year") )
model1 <- as.formula(logPCwelfare_r~lsigperpop20_gini*lnumpar+left+christ+agri+log_pop2+age_65+logPCfedsubs_ptr+year)
est1 <- plm(model1, dat, index = c("cod","year"),  model = "pooling")
cov1 <- c*vcovBK(est1)
coeftest(est1, c*vcovBK(est1))
coeftest(est1, c*vcovHC(est1, cluster = c("group")))
interplot(est1, var1 = "lsigperpop20_gini", var2 = "lnumpar")
library(interplot)
interplot(est1, var1 = "lsigperpop20_gini", var2 = "lnumpar")
