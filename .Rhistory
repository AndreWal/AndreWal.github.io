coeftest(test, vcovHC(test, method= "arellano", type="HC3"))
test <- plm(dir_pc~factor(year)+factor(canton)+ldir_pc5+fed_pc+def_pc+ineqcow+muni+popdens*herf+suffoek+hddi, data = datwint, index = c("canton","year"), model = "pooling")
coeftest(test, vcovHC(test, method= "arellano", type="HC3"))
test <- plm(dir_pc~factor(year)+factor(canton)*as.numeric(year)+ldir_pc5+fed_pc+def_pc+ineqcow+muni+popdens*herf+suffoek+hddi, data = datwint, index = c("canton","year"), model = "pooling")
coeftest(test, vcovHC(test, method= "arellano", type="HC3"))
