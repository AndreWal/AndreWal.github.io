runoff_rdd3 <- rdd_data(y=runoff$cropart, x=runoff$socmarg, cutpoint=0)
regpro2 <- rdd_gen_reg(rdd_object=runoff_rdd3, fun= glm, family=binomial(link=probit), bw = .08)
clusterInf(regpro2, clusterVar=runoff$Electoral_District_Number)
regpro2
library(dplyr)
library(tidyr)
library(readstata13)
library(openxlsx)
library(stringr)
library(statar)
library(zoo)
library(reshape2)
library(lmtest)
library(multiwayvcov)
library(texreg)
library(readstata13)
library(ggplot2)
library(rdd)
library(rddtools)
rm(list=ls())
# Get data
gersw <- read.xlsx("D:/Sync/Dropbox/Papers/Soc_Threat/Data/data.xlsx")
ger <- gersw %>% filter(Country == "GER")
ger$Country <- as.factor(ger$Country)
ger$Round_of_Voting <- as.factor(ger$Round_of_Voting)
ger$fYear <- as.factor(ger$Year)
ger$Surname <- as.factor(ger$Surname)
# Create runoff data
runoff <- ger %>% group_by(Electoral_District_Number,Year2,by_elect) %>% filter(any(Round_of_Voting == 2))
### Competitors & supporters
# Number of political units
units <- ger%>%
separate(Endorsed_by_other_Party, c("Party1","Party2","Party3","Party4","Party5","Party6","Party7"), "#")
units[ , 12:18 ][ units[ , 12:18 ] == "S" ] <- NA # Drop social democrats as supporters; focus on non-socialist parties
count_na <- function(x) sum(!is.na(x))
units$diffparsup <- apply(units[,c("Party1","Party2","Party3","Party4","Party5","Party6","Party7")], 1, count_na) # Number of supporting parties
comp <- units[c("Electoral_District_Number","Year2","by_elect","Party","Party1","Party2","Party3","Party4","Party5","Party6","Party7")]
comp <- melt(comp, id.vars = c("Electoral_District_Number","Year2","by_elect"))
comp <- comp %>% filter(!is.na(value) & value !="S") %>% group_by(Electoral_District_Number,Year2, by_elect) %>%
summarize(diffpar= n_distinct(value)) # Count number of parties by district
runoff <- merge(runoff,comp, by = c("Electoral_District_Number","Year2","by_elect"))
# Create liberal/conservative party vector
table(runoff$Party)
liber <- c("FVP","NL","FoVP","DF","DBB","FVg","NS","DVg","DVP")
con <- c("K","RP","A","DS","M","DSR","CS","DR","BdL","WVg","AVP")
liberalt <- c("FVP","FoVP","DF","DBB","FVg","NS","DVg","DVP")
conalt <- c("K","RP","A","DS","M","DSR","CS","DR","BdL","WVg","AVP","NL")
# Competitors & supporters
runoff <- runoff%>%
separate(Endorsed_by_other_Party, c("Party1","Party2","Party3","Party4","Party5","Party6","Party7"), "#")
runoff[ , 14:20 ][ runoff[ , 14:20 ] == "S" ] <- NA # Drop social democrats as supporters; focus on non-socialist parties
count_na <- function(x) sum(!is.na(x))
runoff$nsup <- apply(runoff[,c("Party1","Party2","Party3","Party4","Party5","Party6","Party7")], 1, count_na) # Number of supporting parties
comp <- runoff %>% group_by(Electoral_District_Number,Year2, by_elect) %>% summarize(comp= n_distinct(Party)) # Number of Competitors
runoff <- merge(runoff,comp, by = c("Electoral_District_Number","Year2","by_elect"))
runoff$supperc <- runoff$nsup/runoff$diffpar # Percent of Supporters
# Non-socialist coordination
# Support of strongest non-socialist Party
runoff3 <- runoff %>% group_by(Electoral_District_Number,Year2, by_elect,Round_of_Voting) %>%
arrange(desc(Vote_share)) %>%
summarize(strnonpar = nth(Party,1), vote = nth(Vote_share,1),strnonpar2 = nth(Party,2), vote2 = nth(Vote_share,2))
runoff3 <- runoff3 %>% filter(Round_of_Voting==1) %>% mutate(marg = vote-vote2)
runoff2 <- runoff %>% filter(Party !="S" & Round_of_Voting!=2) %>% group_by(Electoral_District_Number,Year2, by_elect) %>%
arrange(desc(Vote_share)) %>%
summarize(strnonpar = nth(Party,1), vote = nth(Vote_share,1),strnonpar2 = nth(Party,2), vote2 = nth(Vote_share,2))
runoff4 <- runoff %>% filter(Party =="S" & Round_of_Voting!=2) %>% group_by(Electoral_District_Number,Year2, by_elect) %>%
arrange(desc(Vote_share)) %>%
summarize(socvote = nth(Vote_share,1))
runoff2 <- merge(runoff2,runoff4, by = c("Electoral_District_Number","Year2","by_elect"), all = T)
runoff2$socvote <- ifelse(is.na(runoff2$socvote), 0, runoff2$socvote)
runoff2$socmarg <- runoff2$socvote-runoff2$vote2
test <- merge(runoff,runoff2, by = c("Electoral_District_Number","Year2","by_elect"))
test <- test %>% filter(Party == strnonpar & Vote_share==vote &Round_of_Voting==1 |Party == strnonpar &Round_of_Voting==2)
test <- test %>% arrange(desc(Vote_share)) %>% group_by(Electoral_District_Number,Year,by_elect, Round_of_Voting)  %>% filter(row_number()==1)
test$partyp <- ifelse(test$Party %in% liber, 1, ifelse(test$Party) %in% con, 2,0) # Liberal Party (1) or Conservative Party (2) in second round
test$partypalt <- ifelse(test$Party %in% liberalt, 1, ifelse(test$Party) %in% conalt, 2,0) # Liberal Party (1) or Conservative Party (2) in second round, alternative coding
test$partyp <- ifelse(test$Party %in% liber, 1, ifelse(test$Party) %in% con, 2,0) # Liberal Party (1) or Conservative Party (2) in second round
ifelse(test$Party %in% liber, 1, ifelse(test$Party) %in% con, 2,0)
test$partyp <- ifelse(test$Party %in% liber, 1, ifelse(test$Party %in% con, 2,0)) # Liberal Party (1) or Conservative Party (2) in second round
test$partyp <- ifelse(test$Party %in% liber, 1, ifelse(test$Party %in% con, 2,0)) # Liberal Party (1) or Conservative Party (2) in second round
test$partypalt <- ifelse(test$Party %in% liberalt, 1, ifelse(test$Party %in% conalt, 2,0)) # Liberal Party (1) or Conservative Party (2) in second round, alternative coding
test$partsuplib <- rowSums(apply(test[,c(14:20)],2, function(x){x %in% liber}))
test$partsupcon <- rowSums(apply(test[,c(14:20)],2, function(x){x %in% con}))
test$partsuplibalt <- rowSums(apply(test[,c(14:20)],2, function(x){x %in% liberalt}))
test$partsupconalt <- rowSums(apply(test[,c(14:20)],2, function(x){x %in% conalt}))
test$cropart <- ifelse((test$partyp==1 & test$partsupcon>0) | (test$partyp==2 & test$partsuplib>0),1,0)
test$cropartalt <- ifelse((test$partypalt==1 & test$partsupconalt>0) | (test$partypalt==2 & test$partsuplibalt>0),1,0)
test <- test %>% arrange(Electoral_District_Number,Year2,by_elect,Round_of_Voting) %>% group_by(Electoral_District_Number,Year2,by_elect) %>%
mutate(lnonsocsup = lag(supperc), lVote_share = lag(Vote_share))
test <- test %>% arrange(Electoral_District_Number,Year2,by_elect,Round_of_Voting) %>% group_by(Electoral_District_Number,Year2,by_elect) %>%
mutate(diffnonsocsup = supperc-lnonsocsup, diffVote_share = Vote_share-lVote_share)
test <- test[,c("Electoral_District_Number","Year2","by_elect","lnonsocsup","diffnonsocsup","Round_of_Voting","diffVote_share","lVote_share","socmarg","cropart","cropartalt")]
test <- test %>% filter(Round_of_Voting==2)
View(test)
# Left second round
runoff2 <- runoff %>% group_by(Electoral_District_Number,Year2,by_elect) %>%
mutate(leftIIr = ifelse(Party=="S",1,0), minIIr = ifelse(Party=="Minority",1,0)) %>%
filter(Round_of_Voting==2) %>% summarize(leftIIround = sum(leftIIr), minIIround = sum(minIIr))
runoff <- merge(runoff,runoff2, by = c("Electoral_District_Number","Year2","by_elect"))
# Differenced values
runoff$turn <- runoff$Turnout/runoff$Eligible_Voters
runoff <- runoff %>% group_by(Country, Electoral_District_Number,Year,by_elect, Round_of_Voting)  %>% filter(row_number()==1)
runoff <- runoff %>% arrange(Round_of_Voting) %>% group_by(Electoral_District_Number,Year2,by_elect) %>%
mutate(lcomp = lag(comp), lturn = lag(turn))
runoff <- runoff %>% mutate(diffcomp = comp-lcomp, diffturn = turn-lturn)
runoff <- runoff %>% filter(Round_of_Voting==2)
runoff <- merge(runoff,test, by = c("Electoral_District_Number","Year2","by_elect"))
runoff <- merge(runoff,runoff3, by = c("Electoral_District_Number","Year2","by_elect"))
runoff <- as.data.frame(runoff)
save.dta13(runoff,"D:/Sync/Dropbox/Papers/Soc_Threat/Data/data.dta")
est1 <- lm(diffturn~factor(Year)+factor(Electoral_District_Number)+leftIIround+diffnonsocsup+lnonsocsup+lcomp+marg, data = runoff)
summary(est1)
coeftest(est1,cluster.vcov(est1, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))
plot(runoff$diffturn,runoff$diffnonsocsup)
est1 <- lm(diffnonsocsup~factor(Year)+poly(marg,2,raw=T)+leftIIround+lnonsocsup+lcomp, data = runoff)
summary(est1)
coeftest(est1,cluster.vcov(est1, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))
# Table 1
est0 <- lm(diffnonsocsup~leftIIround, data = runoff)
cov0 <- as.matrix(sqrt(diag(cluster.vcov(est0, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))))
pval0 <- coeftest(est0,cluster.vcov(est0, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))[,4]
rownames(cov0) <- (names(est0$coefficients))
est1 <- lm(diffnonsocsup~factor(Year)+leftIIround, data = runoff)
cov1 <- as.matrix(sqrt(diag(cluster.vcov(est1, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))))
pval1 <- coeftest(est1,cluster.vcov(est1, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))[,4]
rownames(cov1) <- (names(est1$coefficients))
est2 <- lm(diffnonsocsup~factor(Year)+leftIIround+minIIround+lnonsocsup+lcomp+poly(marg,2,raw=T), data = runoff)
cov2 <- as.matrix(sqrt(diag(cluster.vcov(est2, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))))
pval2 <- coeftest(est2,cluster.vcov(est2, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))[,4]
rownames(cov2) <- (names(est2$coefficients))
est3 <- lm(diffnonsocsup~factor(Year)+factor(Electoral_District_Number)+leftIIround, data = runoff)
cov3 <- as.matrix(sqrt(diag(cluster.vcov(est3, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))))
pval3 <- coeftest(est3,cluster.vcov(est3, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))[,4]
rownames(cov3) <- (names(est3$coefficients))
est4 <- lm(diffnonsocsup~factor(Year)+factor(Electoral_District_Number)+leftIIround+minIIround+lnonsocsup+lcomp+poly(marg,2,raw=T), data = runoff)
cov4 <- as.matrix(sqrt(diag(cluster.vcov(est4, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))))
pval4 <- coeftest(est4,cluster.vcov(est4, cbind(runoff$Electoral_District_Number,runoff$Year), force_posdef = TRUE))[,4]
rownames(cov4) <- (names(est4$coefficients))
texreg(list(est0,est1,est2,est3,est4), file = "D:/Sync/Dropbox/Papers/Soc_Threat/Paper/estimation_nonsoccoord.tex", stars = c(0.01, 0.05, 0.1),
custom.model.names = c("No FE","Year FE","Year FE","Year/District FE","Year/District FE"),
booktabs = T, dcolumn = T, table = F,
override.se = list(c(cov0),c(cov1),c(cov2),c(cov3),c(cov4)),
override.pvalues = list(c(pval0),c(pval1),c(pval2),c(pval3),c(pval4)),
omit.coef = "Electoral_District_Number|Year",use.packages = F, leading.zero = FALSE, reorder.coef = c(2:7,1),
custom.note = c("Cluster-Robust Standard Errors by Electoral District and Year in Parentheses. $^{*}$p$<$0.1; $^{**}$p$<$0.05; $^{***}$p$<$0.01."),
custom.coef.names = c( "Intercept","Socialist in Run-Off","Minority in Run-Off",
"First Round Support among Competitors","First Round Numb. Competitors",
"First Round Margin","First Round Margin sq."),
include.aic = TRUE, include.nobs = TRUE, include.missings=F,include.bic = F, include.deviance = F, include.loglik = F,
include.rsquared = F, include.maxrs = F, include.events = F)
hist(runoff$lcomp)
mean(runoff$lcomp)
table(runoff$leftIIround, exclude = NULL)
ggplot(runoff, aes(factor(leftIIround), diffnonsocsup))+geom_boxplot()+ geom_jitter(width = 0.05)
runoff$Year3 <- as.factor(runoff$Year)
runoff$id <- as.factor(runoff$Electoral_District_Number)
