library(readstata13)
library(openxlsx)
library(dplyr)
library(reshape2)
library(purrr)
library(tidyr)
library(zoo)
rm(list=ls())
### Read data
source("D:/Sync/Dropbox/Papers/Canton_Exec_Data/Graphs/Gen_Data.R")
names(fints)[names(fints)=="Jahr"] <- "year"
fints <- fints %>% mutate(left = SP+GP+CSP, lib = FDP+Demo+LDU+BDP, con = CVP+Kon+SVP+Lib) %>% select(Code,year,left,lib,con)
colnames(fints) <- c("canton","year","left","lib","con")
infm <- read.dta13("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/Infant_Mort.dta")
sufr <- read.xlsx("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/Suffrage.xlsx")
mun <- read.xlsx("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/muni.xlsx")
hddi <- read.csv("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/HDDI_2016.csv")
hddi <- hddi[c(2:4)]
colnames(hddi) <- c("hddi","year","cantonnr")
hddiind <- read.dta13("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/DD_hist_data.dta")
popdens <- read.xlsx("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/popdens.xlsx")
popdens <- melt(popdens, id.vars = "year")
colnames(popdens) <- c("year","canton","popdens")
popdens$canton <- as.character(popdens$canton)
pop <- read.xlsx("D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/pop.xlsx")
pop <- melt(pop, id.vars = "year")
colnames(pop) <- c("year","canton","pop")
pop$canton <- as.character(pop$canton)
# Taxation data
# Inequality different categories
load("D:/Sync/Dropbox/Historical Democratization of Switzerland/Data/Secondary Data/Inequality measure animals/Gini.Cows.RData")
ineqcow <- as.data.frame(GINI.matrix)
ineqcow <- cbind(ineqcow, canton = row.names(ineqcow))
ineqcow <- melt(ineqcow, id.vars = "canton")
colnames(ineqcow) <- c("canton","year","ineqcow")
load("D:/Sync/Dropbox/Historical Democratization of Switzerland/Data/Secondary Data/Inequality measure animals/Gini.Goats.RData")
ineqgo <- as.data.frame(GINI.matrix.goats)
ineqgo <- cbind(ineqgo, canton = row.names(ineqgo))
ineqgo <- melt(ineqgo, id.vars = "canton")
colnames(ineqgo) <- c("canton","year","ineqgo")
load("D:/Sync/Dropbox/Historical Democratization of Switzerland/Data/Secondary Data/Inequality measure animals/Gini.Pigs.RData")
ineqpi <- as.data.frame(GINI.matrix.pigs)
ineqpi <- cbind(ineqpi, canton = row.names(ineqpi))
ineqpi <- melt(ineqpi, id.vars = "canton")
colnames(ineqpi) <- c("canton","year","ineqpi")
load("D:/Sync/Dropbox/Historical Democratization of Switzerland/Data/Secondary Data/Inequality measure animals/Gini.Sheep.RData")
ineqsh <- as.data.frame(GINI.matrix.sheep)
ineqsh <- cbind(ineqsh, canton = row.names(ineqsh))
ineqsh <- melt(ineqsh, id.vars = "canton")
colnames(ineqsh) <- c("canton","year","ineqsh")
load("D:/Sync/Dropbox/Historical Democratization of Switzerland/Data/Secondary Data/Inequality measure animals/Gini.Horse.RData")
ineqho <- as.data.frame(GINI.matrix.horses)
ineqho <- cbind(ineqho, canton = row.names(ineqho))
ineqho <- melt(ineqho, id.vars = "canton")
colnames(ineqho) <- c("canton","year","ineqho")
### Merge data
fipar <- list(hddi, hddiind, sufr, infm) %>% reduce(full_join, by = c("cantonnr" = "cantonnr","year" = "year"))
fipar <- fipar %>% fill(canton,Suffrage_Age,Suffrage_Religion,Suffrage_fallit,Suffrage_wealth,Suffrage_Income,Suffrage_other)
ineq <- list(ineqcow, ineqgo, ineqpi,ineqsh,ineqho) %>% reduce(full_join, by = c("canton" = "canton","year" = "year"))
ineq$year <- as.numeric(levels(ineq$year))[ineq$year]
ineq$canton <- as.character(ineq$canton)
findat <- list(popdens, pop,mun,ineq,fipar,fints) %>% reduce(full_join, by = c("canton" = "canton","year" = "year"))
findat$ineqcow <- ifelse(findat$ineqcow == "NaN", NA,findat$ineqcow)
count_na <- function(x) sum(x != 0)
findat$suffmax <- apply(findat[,c("Suffrage_Religion","Suffrage_fallit","Suffrage_wealth","Suffrage_Income","Suffrage_other")], 1, count_na)
findat$suff <- ifelse(findat$suffmax >0,1,0)
findat$suffoekmax <- apply(findat[,c("Suffrage_fallit","Suffrage_wealth","Suffrage_Income","Suffrage_other")], 1, count_na)
findat$suffoek <- ifelse(findat$suffoekmax >0,1,0)
findat <- findat %>% select(-new, -Suffrage_Age,-Suffrage_fallit, -Suffrage_wealth,-Suffrage_Income,-Suffrage_other,-Suffrage_Religion)
findat <- findat[complete.cases(findat[ , 1]),]
rm(list=setdiff(ls(), "findat"))
### Interpolation population density and inequality
findat <- findat %>% filter(canton != "JU") %>% arrange(canton, year) %>%
group_by(canton) %>%
mutate(popdens = na.approx(popdens, maxgap = 40, na.rm=FALSE), pop = na.approx(pop, maxgap = 40, na.rm=FALSE),
ineqcow = na.approx(ineqcow, maxgap = 40, na.rm=FALSE), ineqho = na.approx(ineqho, maxgap = 40, na.rm=FALSE))
# Fill down suffrage restriction and municipalities
findat <- findat %>% arrange(canton, year) %>% fill(muni, suffmax, suff)
# Extrapolate municipalities and inequality
findat <- findat %>% arrange(canton, year) %>%
group_by(canton) %>%
mutate(muni = na.spline(muni), ineqcow = na.spline(ineqcow), ineqho = na.spline(ineqho))
# Set maximum period of the data
findat <- findat %>% filter(year<1931 & year>1829)
save(findat, file="D:/Sync/Dropbox/Historical Democratization of Switzerland/Papers/Direct_Tax/Data/analysis_data.RData")
View(findat)
