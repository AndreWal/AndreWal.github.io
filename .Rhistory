# To do: Lag independent variables and difference current
# values of independent & dependent variable(s) (General ECM, De Boef & Keele 2008)
# muni: Number of Municipalities
# suffmax: Number of categories suffrage restrictions
# suffoekmax: Number of categories suffrage restrictions (economic groups only)
# suffoek: Do suffrage restrictions (economic groups only) exist; yes 1, no 0
# dir_sh: Share direct taxes
# fed_sh: Share federal transfers
# def_sh: Share deficits
# indir_sh: Share indirect taxes
# lux_sh: Share taxes on luxury goods
### ECMs
# Trends! --> Differencing!
findat <- findat %>% arrange(canton,year) %>% group_by(canton) %>%
mutate(ldir_pc = lag(dir_pc), ddir_pc = dir_pc-ldir_pc, lddir_pc = lag(ddir_pc))
# Estimations, try substituting numpar with maj/herf
test <- plm(dir_pc~ldir_pc+fed_pc+def_pc+ineqcow+suffoek+hddi+muni+popdens*herf, data = findat, index = c("canton","year"), model = "pooling")
coeftest(test, vcovHC(test, method= "arellano", type="HC3"))
test <- plm(dir_pc~factor(canton)+ldir_pc+fed_pc+def_pc+ineqcow+suffoek+hddi+muni+popdens*herf, data = findat, index = c("canton","year"), model = "pooling")
coeftest(test, vcovHC(test, method= "arellano", type="HC3"))
test <- plm(dir_pc~factor(year)+factor(canton)+ldir_pc+fed_pc+def_pc+ineqcow+suffoek+hddi+muni+popdens*herf, data = findat, index = c("canton","year"), model = "pooling")
coeftest(test, vcovHC(test, method= "arellano", type="HC3"))
test <- plm(dir_pc~factor(year)+factor(canton)*as.numeric(year)+ldir_pc+fed_pc+def_pc+ineqcow+suffoek+hddi+muni+popdens*herf, data = findat, index = c("canton","year"), model = "pooling")
coeftest(test, vcovHC(test, method= "arellano", type="HC3"))
### ECMs without interpolation
set <- seq(1830, 1930, 5)
datwint <- subset(findat, year %in% set)
# Trend again!
datwint <- datwint %>% arrange(canton,year) %>% group_by(canton) %>%
mutate(ldir_sh5 = lag(dir_sh), ldir_pc5 = lag(dir_pc), ddir_pc5 = dir_pc-ldir_pc5, lddir_pc5 = lag(ddir_pc5))
