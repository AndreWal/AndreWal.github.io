library(ggplot2)
library(readstata13)
library(openxlsx)
library(cowplot)
# Data
rm(list=ls())
dat<- read.dta13("D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Data/Hist/final2.dta")
dat$sigperpop20_gini <- dat$sigperpop20_gini*100
test1 <- subset(dat, konkalt==3)
test2 <- subset(test1, konkmiou>26)
nrow(test2)/nrow(test1)
coef <- read.csv2("D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Estimation/coef.csv")
coef2 <- read.csv2("D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Estimation/coef2.csv")
vcov <- read.csv2("D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Estimation/vcov.csv")
vcov2 <- read.csv2("D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Estimation/vcov2.csv")
rownames(vcov) <- vcov$X
rownames(vcov2) <- vcov2$X
### Calculate ME/CI
# Range of the Moderator
modconc <- c(0,1)
modmiou <- seq(min(dat$konkmiou),max(dat$konkmiou),(max(dat$konkmiou)-min(dat$konkmiou))/200)
# Marginal Effect Size
conccoef <- coef$konk+coef$Inter*modmiou
mioucoef <- coef$konkmiou+coef$Inter*modconc
#Reforms
conccoef2 <- coef2$kref2+coef2$Inter2*modmiou
conccoef3 <- coef2$kref3+coef2$Inter4*modmiou
conccoef4 <- coef2$kref4+coef2$Inter4*modmiou
mioucoef2 <- coef2$konkmiou+coef2$Inter2*modconc
mioucoef3 <- coef2$konkmiou+coef2$Inter3*modconc
mioucoef4 <- coef2$konkmiou+coef2$Inter4*modconc
# SE/CIs using the Delta Method
concvar <- vcov["konk","konk"] + (modmiou^2)*vcov["Inter", "Inter"] + 2*modmiou*vcov["konk", "Inter"]
concse <- sqrt(concvar)
z_score <- qnorm(1 - ((1 - .95)/2))
conc_upp <- conccoef + z_score*concse
conc_low <- conccoef - z_score*concse
miouvar <- vcov["konkmiou","konkmiou"] + (modconc^2)*vcov["Inter", "Inter"] + 2*modconc*vcov["konkmiou", "Inter"]
miouse <- sqrt(miouvar)
miou_upp <- mioucoef + z_score*miouse
miou_low <- mioucoef - z_score*miouse
conceff <- data.frame(conccoef,conc_upp,conc_low, modmiou,((exp(conccoef)-1)*100))
mioueff <- data.frame(mioucoef, miou_upp,miou_low, modconc)
# Reforms
concvar2 <- vcov2["kref2","kref2"] + (modmiou^2)*vcov2["Inter2", "Inter2"] + 2*modmiou*vcov2["kref2", "Inter2"]
concse2 <- sqrt(concvar2)
conc_upp2 <- conccoef2 + z_score*concse2
conc_low2 <- conccoef2 - z_score*concse2
concvar3 <- vcov2["kref3","kref3"] + (modmiou^2)*vcov2["Inter3", "Inter3"] + 2*modmiou*vcov2["kref3", "Inter3"]
concse3 <- sqrt(concvar3)
conc_upp3 <- conccoef3 + z_score*concse3
conc_low3 <- conccoef3 - z_score*concse3
concvar4 <- vcov2["kref4","kref4"] + (modmiou^2)*vcov2["Inter4", "Inter4"] + 2*modmiou*vcov2["kref4", "Inter4"]
concse4 <- sqrt(concvar4)
conc_upp4 <- conccoef4 + z_score*concse4
conc_low4 <- conccoef4 - z_score*concse4
conceff2 <- data.frame(conccoef2,conc_upp2,conc_low2, modmiou,((exp(conccoef2)-1)*100))
conceff3 <- data.frame(conccoef3,conc_upp3,conc_low3, modmiou,((exp(conccoef3)-1)*100))
conceff4 <- data.frame(conccoef4,conc_upp4,conc_low4, modmiou,((exp(conccoef4)-1)*100))
miouvar2 <- vcov2["konkmiou","konkmiou"] + (modconc^2)*vcov2["Inter2", "Inter2"] + 2*modconc*vcov2["konkmiou", "Inter2"]
miouse2 <- sqrt(miouvar2)
miou_upp2 <- mioucoef2 + z_score*miouse2
miou_low2 <- mioucoef2 - z_score*miouse2
miouvar3 <- vcov2["konkmiou","konkmiou"] + (modconc^2)*vcov2["Inter3", "Inter3"] + 2*modconc*vcov2["konkmiou", "Inter3"]
miouse3 <- sqrt(miouvar3)
miou_upp3 <- mioucoef3 + z_score*miouse3
miou_low3 <- mioucoef3 - z_score*miouse3
miouvar4 <- vcov2["konkmiou","konkmiou"] + (modconc^2)*vcov2["Inter4", "Inter4"] + 2*modconc*vcov2["konkmiou", "Inter4"]
miouse4 <- sqrt(miouvar4)
miou_upp4 <- mioucoef4 + z_score*miouse4
miou_low4 <- mioucoef4 - z_score*miouse4
mioueff2 <- data.frame(mioucoef2, miou_upp2,miou_low2, modconc)
mioueff3 <- data.frame(mioucoef3, miou_upp3,miou_low3, modconc)
mioueff4 <- data.frame(mioucoef4, miou_upp4,miou_low4, modconc)
View(conceff3)
test1 <- subset(dat, konkalt==3)
test2 <- subset(test1, konkmiou>47)
nrow(test2)/nrow(test1)
library(readstata13)
library(spdep)
library(rgdal)
library(plm)
library(lmtest)
library(plyr)
library(stargazer)
library(ggplot2)
library(cowplot)
rm(list=ls())
# Subset Data
dat3 <- read.dta13("D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Data/Hist/final.dta")
dat3 <- subset(dat3, dat3$year >1929 & dat3$year < 2001)
dat2 <- subset(dat3, dat3$year >1929 & dat3$year < 1976)
dat2$konkmiou <- dat2$konkmiou*100
dat2$konkmigin <- dat2$konkmigin*100
# Spatial Weights
map <- readOGR(dsn = "D:/Sync/Dropbox/Papers/Cantons_Poor_Law/data/Spatial_Data", layer = "Kantons_without_Jura")
levels(map@data$AK) <- c(levels(map@data$AK), "BE")
levels(map@data$Name) <- c(levels(map@data$Name), "Bern")
map@data$AK[map@data$AK %in% NA] <- "BE"
map@data$Name[map@data$Name %in% NA] <- "Bern"
test <- map@data
nbob1 <- poly2nb(map, row.names = map@data$AK)
nbob2 <- knn2nb(knearneigh(coordinates(map), k = 4))
wei1 <- nb2mat(nbob1,  style="minmax", zero.policy = T)
wei2 <- nb2mat(nbob1,  style="W", zero.policy = T)
colnames(wei1) <- row.names(wei1)
wei1 <- wei1[order(row.names(wei1)),order(colnames(wei1))]
# Create Spatial Lags
weisocex <- list()
for (i in 1:length(unique(dat2$year))){
i <- i+1929
datayr <- subset(dat2, dat2$year == i)
socexp <- datayr$logPCwelfare_r
datayr$spsoc <- wei1%*%socexp
datayr$spsoc2 <- wei2%*%socexp
weisocex[[i]] <- datayr
i <- i-1929
}
dat <- rbind.fill(weisocex)
dat2 <- pdata.frame(dat, index = c("cod","year"))
## Coefficient of Variation
yr <- list()
cvar <- list()
total <- list()
for (i in 1:length(unique(dat3$year))){
i <- i+1929
datyr <- subset(dat3, year==i)
cvar[[i]] <- sqrt(exp(var(datyr$logPCwelfare_r))-1)
yr[[i]] <- i
total[[i]] <- sum(exp(datyr$logPCwelfare_r))
i <- i+1929
}
covar <- data.frame(unlist(total),unlist(cvar),unlist(yr))
save.dta13(dat, "D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Data/Hist/final2.dta")
p1 <- ggplot(data = covar, aes(x=unlist.yr., y=unlist.total.))+geom_line(color = "black")+theme_bw()+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Social Spending of the Swiss Cantons 1930-2000",
x = "Year",
y = "Social Spending per capita")
p2 <- ggplot(data = covar, aes(x=unlist.yr., y=unlist.cvar.))+geom_line(color = "black")+theme_bw()+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(title = "Convergence of Social Spending of the Swiss Cantons 1930-2000",
x = "Year",
y = "Coefficient of Variation")
plot <- plot_grid(p1,p2, nrow = 2, align = "v")
ggsave("D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Paper/devsoc.eps", height=7, width=10, units='in',device=cairo_ps)
# Summary Statistics
sumdat <- dat[,c("logPCwelfare_r","konk","konkalt","konkmiou","konkmigin","infmort","depratio","empl2nd","perc_urban",
"log_pop2","logPCfedsubs_ptr","sigperpop20_gini","Mandbugref","dfs","dummy_prop","left","numpar","spsoc2")]
stargazer(sumdat, summary = T, title = "Summary Statistics", font.size = "small",
out = "D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Paper/sumst.tex",
covariate.labels = c("ln Soc. Exp. p.c.","Concordat","Concordat Reforms","Outward Mig. Conc",
"Inward Mig. Conc.","Infant Mortality",
"$\\%$ Dependency Ratio","$\\%$ Industrial Labor Force","$\\%$ Urbanization","ln Population Size",
"ln Federal Subsidies","$\\%$ Sig. Initiative","Mand. Budget Ref.","Female Suffrage",
"PR Legislative","Left Parties","Num. Parties","Spatial Lag"))
# ECM
test <- plm(fdlogPCwelfare_r~logPCwelfare_r+konk*konkmiou+shfor+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2 , dat2, effect = "twoways")
coeftest(test,vcovBK(test, cluster = c("group","time")))
est1 <- plm(fdlogPCwelfare_r~logPCwelfare_r+as.factor(year)+konk*konkmiou+konk*konkmigin, dat2, model = "pooling")
cov1 <- as.matrix(sqrt(diag(vcovBK(est1, cluster = "time"))))
rownames(cov1) <- (row.names(est1$vcov))
coeftest(est1,vcovBK(est1, cluster = "group"))
est2 <- plm(fdlogPCwelfare_r~logPCwelfare_r+konk*konkmiou+konk*konkmigin, dat2, effect = "twoways")
cov2 <- as.matrix(sqrt(diag(vcovBK(est2, cluster = "time"))))
rownames(cov2) <- (row.names(est2$vcov))
est3 <- plm(fdlogPCwelfare_r~logPCwelfare_r+as.factor(year)+konk*konkmiou+konk*konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2 , dat2, model = "pooling")
cov3 <- as.matrix(sqrt(diag(vcovBK(est3, cluster = "time"))))
rownames(cov3) <- (row.names(est3$vcov))
est4 <- plm(fdlogPCwelfare_r~logPCwelfare_r+konk*konkmiou+konk*konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2 , dat2, effect = "twoways")
cov4 <- as.matrix(sqrt(diag(vcovBK(est4, cluster = "time"))))
rownames(cov4) <- (row.names(est4$vcov))
est6 <- plm(flogPCwelfare_r~fdlogPCwelfare_r+as.factor(year)+konk*konkmiou+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2 |
logPCwelfare_r+as.factor(year)+konk*konkmiou+konkmigin+shfor+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2
, dat2, model = "pooling")
cov6 <- as.matrix(sqrt(diag(vcovBK(est6, cluster = "time"))))
rownames(cov6) <- (row.names(est6$vcov))
est7 <- plm(fdlogPCwelfare_r~logPCwelfare_r+as.factor(year)+factor(konkalt)*konkmiou+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2 , dat2, model = "pooling")
cov7 <- as.matrix(sqrt(diag(vcovBK(est7, cluster = "time"))))
rownames(cov7) <- (row.names(est7$vcov))
est8 <- plm(fdlogPCwelfare_r~logPCwelfare_r+factor(konkalt)*konkmiou+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2 , dat2, effect = "twoways")
cov8 <- as.matrix(sqrt(diag(vcovBK(est8, cluster = "time"))))
rownames(cov8) <- (row.names(est8$vcov))
est9 <- plm(flogPCwelfare_r~fdlogPCwelfare_r+as.factor(year)+factor(konkalt)*konkmiou+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2 |
logPCwelfare_r+as.factor(year)+factor(konkalt)*konkmiou+konkmigin+shfor+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2
, dat2, model = "pooling")
cov9 <- as.matrix(sqrt(diag(vcovBK(est9, cluster = "time"))))
rownames(cov9) <- (row.names(est9$vcov))
stargazer(est1, est2,est3,est4,est6,est7,est8,est9,
se = list(cov1,cov2,cov3,cov4,cov6,cov7,cov8,cov9), type = "latex",
out = "D:/Sync/Dropbox/Papers/Cantons_Poor_Law_II/Paper/regfin.tex", omit = c("year","fdlogPCwelfare",
"infmort","empl2nd","depratio","perc_urban","log_pop2","logPCfedsubs_ptr","sigperpop20_gini",
"numpar","left","dfs","dummy_prop","Mandbugref","spsoc2"),
font.size = "scriptsize", dep.var.labels.include = F,
dep.var.caption = "$\\Delta$ ln Social Expenditure per Capita",
no.space = T, keep.stat = c("adj.rsq", "n"),
add.lines = list(c("Year FE","Yes","Yes","Yes","Yes","Yes","Yes","Yes","Yes"),
c("Canton FE","No","Yes","No","Yes","No","No","Yes","No"),
c("Controls","No","No","Yes","Yes","Yes","Yes","Yes","Yes"),
c("Long Term Effects","No","No","No","No","Yes","No","No","Yes"),
c("Cluster","25","25","25","25","25","25","25","25")),
notes = c("Panel-Corrected Standard Errors in Parentheses. $^{*}$p$<$0.1; $^{**}$p$<$0.05; $^{***}$p$<$0.01"),
notes.append = F, order = c(1,52:53,48,67:68),
covariate.labels = c("lag Social Exp.","Outward Migration","Inward Migration","Concordat",
"Conc*Outward Mig.","Conc*Inward Mig.","Conc. 1923","Conc. 1937",
"Conc. 1959","Conc. 1923*Outward Mig.","Conc. 1937*Outward Mig.",
"Conc. 1959*Outward Mig."), float.env = "sidewaystable",
title = "Concordat Accession, Outward Migration, and Social Expenditure Growth")
