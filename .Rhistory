# PR Swiss Cantons Data
library(openxlsx)
library(dplyr)
library(readstata13)
library(brglm)
library(multiwayvcov)
library(lmtest)
library(effects)
library(survival)
library(ggplot2)
library(ggrepel)
library(MASS)
library(texreg)
rm(list=ls())
source("D:/Sync/Dropbox/Papers/Canton_Exec_Data/Graphs/Gen_Data.R")
names(fints)[names(fints)=="Jahr"] <- "year"
# Dominant Party Weighting
fints$dommax <- apply(fints[2:16], 1, function(x) max(x))
fints$herf <- apply(fints[2:16], 1, function(x) sum(x^2))
fints$dom <- ifelse(fints$FDP>=.5 | fints$Rad>=.5,1,0)
fints$dom <- ifelse(fints$CVP>=.5 ,2,fints$dom)
fints$dom <- ifelse(fints$Lib>=.5 | fints$Kon>=.5 ,3,fints$dom)
fints$Code <- as.factor(fints$Code)
fints <- fints %>%
group_by(Code, dom,cumsum(c(FALSE, diff(dom) < 0))) %>%
mutate(yepo = row_number())
fints <- fints %>% mutate(yepo = ifelse(dom==0,0,yepo))
# PR and Event History Structure
pr <- read.dta13("D:/Sync/Dropbox/Papers/PR_Cantons/Data/Lutz_Data.dta")
dat <- merge(pr,fints, by.x = c("kann","jahr"), by.y = c("Code","year"))
dat <- dat %>% mutate(time = duration, time2 = duration^2, time3 = duration^3)
save.dta13(dat,"D:/Sync/Dropbox/Papers/PR_Cantons/Data/fin.dta")
# Graph
dis <- read.xlsx("D:/Sync/Dropbox/Papers/PR_Cantons/Data/Pre_Post_Seat_Share.xlsx",1)
dis <- dis %>% mutate(loss = sesh_pre_I-sesh_post_I) %>%  mutate(Dom_Pos=as.factor(Dom_Pos))
dis <- subset(dis, !is.na(Dom_Pos)  & !is.na(loss))
t.test(loss~Dom_Pos, dis)
ggplot(data = dis,aes(y=loss,x=Dom_Pos))+geom_boxplot()+
theme_bw()+theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(y = "Seat Share Loss after Introduction of PR",
x = "Dominant Party Position Toward PR")
ggsave("D:/Sync/Dropbox/Papers/PR_Cantons/Paper/loss.eps", height=7, width=15, units='in',device=cairo_ps)
# Effective electoral threshold
test <- read.xlsx("D:/Sync/Dropbox/Papers/Pol_Cantons_PostDoc/Electoral Laws/District_Quota_distribution_Cantons(7372).xlsx",1)
test[is.na(test)] <- 0
test2 <- test %>% filter(Canton =="AG" & Year ==1921 | Canton =="BE" & Year ==1922 | Canton =="BL" & Year ==1919 |
Canton =="BS" & Year ==1905 | Canton =="FR" & Year ==1921 | Canton =="GE" & Year ==1892 |
Canton =="GL" & Year ==1920 | Canton =="LU" & Year ==1911 | Canton =="NE" & Year ==1898 |
Canton =="NW" & Year ==1982 | Canton =="OW" & Year ==1986 | Canton =="SG" & Year ==1912 |
Canton =="SH" & Year ==1954 | Canton =="SZ" & Year ==1900 | Canton =="TG" & Year ==1917 |
Canton =="VD" & Year ==1961 | Canton =="VS" & Year ==1921 | Canton =="ZG" & Year ==1894 |
Canton =="ZH" & Year ==1917 | Canton =="SO" & Year ==1896 | Canton =="UR" & Year ==1992 |
Canton =="TI" & Year ==1892)
countvar <- as.numeric(colnames(test2))
countvar <- subset(countvar,!is.na(countvar))
test2$meddis <- apply(test2[,3:45],1,function(x){median(rep(countvar,x))})
test2$nthres <- 75/((test2$meddis+1)*sqrt(test2$Districts))
test2$nthres2 <- 75/(test2$meddis+1)
dis <- read.xlsx("D:/Sync/Dropbox/Papers/PR_Cantons/Data/Pre_Post_Seat_Share.xlsx",1)
dis <- dis %>% mutate(loss = sesh_pre_I-sesh_post_I) %>%  mutate(Dom_Pos=as.factor(Dom_Pos))
test3 <- merge(dis, test2, by.x = "code", by.y = "Canton", all = T)
test3 <- test3[c("code","nthres","Dom_Pos","loss","sesh_pre_I","sesh_post_I","nthres2","Dom_Party")]
test3$nthres <- ifelse(test3$code =="FR", 15, test3$nthres)
test3$nthres <- ifelse(test3$code =="NE", 15, test3$nthres)
test3$nthres <- ifelse(test3$code =="SG", 2.9, test3$nthres)
test3$nthres <- ifelse(test3$code =="VD", 5, test3$nthres)
test3$nthres2 <- ifelse(test3$code =="FR", 15, test3$nthres2)
ggplot(test3, aes(x=loss,y=nthres,label=code))+geom_point()+geom_smooth(method = "lm", se = FALSE,color = "black")+ theme_bw()+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(x = "Seat Share Loss after PR Introduction",y = "Effective Electoral Threshold")+
geom_text_repel()
ggsave("D:/Sync/Dropbox/Papers/PR_Cantons/Paper/lossthres.eps", height=7, width=15, units='in',device=cairo_ps)
ggplot(test3, aes(x=loss,y=nthres2,label=code))+geom_point()+geom_smooth(method = "lm", se = FALSE,color = "black")+ theme_bw()+
theme(axis.line.x = element_line(colour = "black"), axis.line.y = element_line(colour = "black"),
panel.border = element_blank())+labs(x = "Seat Share Loss after PR Introduction",y = "Effective Median Threshold")+
geom_text_repel()
ggsave("D:/Sync/Dropbox/Papers/PR_Cantons/Paper/lossthres2.eps", height=7, width=15, units='in',device=cairo_ps)
m1 <- lm(loss~Dom_Pos, test3)
m2 <- lm(nthres2~Dom_Pos, test3)
m3 <- lm(loss~nthres2, test3)
texreg(list(m1,m2,m3), file = "D:/Sync/Dropbox/Papers/PR_Cantons/Paper/regres.tex",
custom.model.names = c("Seat Loss","Threshold","Seat Loss"),
booktabs = F, dcolumn = F, table = F, stars = c(0.001, 0.01, 0.05, 0.1),center = T,
custom.coef.names = c( "Intercept","Dominant Party Support","Eff. Median Threshold"),include.adjrs = F, include.rmse = F,
custom.note = "Note: Standard Errors in parentheses. \\sym{+} \\(p<0.1\\), \\sym{*} \\(p<0.05\\), \\sym{**} \\(p<0.01\\), \\sym{***} \\(p<0.001\\)")
# Robustness Test for Glarus
# Pre-PR Seat share as a function of party position and post-PR seat share
prePRd <- m1$coefficients[1]+test3$sesh_post_I[9]
prePRd
m3$coefficients[1]
m3$coefficients[2]
prePRn <- m3$coefficients[1]-m3$coefficients[2]*test3$nthres2[9]+test3$sesh_post_I[9]
prePRn
m3$coefficients[1]-m3$coefficients[2]*test3$nthres2[9]
m3$coefficients[1]
m3$coefficients[2]
test3$nthres2[9]
m3$coefficients[2]*test3$nthres2[9]
m3$coefficients[1]
test3$sesh_post_I[9]
prePRn <- m3$coefficients[1]-m3$coefficients[2]*test3$nthres2[9]+test3$sesh_post_I[9]
prePRn
m3$coefficients[1]
-m3$coefficients[2]*test3$nthres2[9]
prePRn <- m3$coefficients[1]+m3$coefficients[2]*test3$nthres2[9]+test3$sesh_post_I[9]
prePRn
prePRd
View(test3)
