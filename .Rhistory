## Merge Voting Data for PR Switzerland
library(plyr)
library(reshape2)
library(stringr)
rm(list=ls())
elect <- read.csv2("D:/Sync/Dropbox/Papers/PR_NR_CH/Data/Elections/Elections_NR_1899_1908_1917.csv")
vote <- read.csv2("D:/Sync/Dropbox/Papers/PR_NR_CH/Data/Voting/Voting_of_Members.csv")
vote$Vote[vote$Vote == 2] <- NA
# Manipulate data
elect$name2 <- sub('.*\\ ', '', elect$Name)
vote2 <- subset(vote, vote$Unit == "NR")
### Data for Analysis
# Seat-Vote Dispro. Variable
fulldat <- list()
for (j in unique(elect$Year)){
elect2 <- subset(elect, elect$Year == j)
findat <- list()
for (k in unique(elect2$Electoral_District_Number)){
elect3 <- subset(elect2, elect2$Electoral_District_Number == k)
votsea <- list()
for (i in unique(elect3$Round_of_Voting)){
test <- subset(elect3, elect3$Round_of_Voting == i)
voters <- aggregate(test$Votes_Received, list(Party = test$Party), sum)
seats <- aggregate(test$Elected, list(Party = test$Party), sum)
testdat2 <- merge(voters, seats, by = "Party")
testdat2$numpar <- rep(length(unique(test$Party)), nrow(testdat2))
testdat2$seatnum <- rep(sum(testdat2$x.y), nrow(testdat2))
testdat2$votenum <- rep(sum(testdat2$x.x), nrow(testdat2))
testdat2$votesh <- testdat2$x.x/testdat2$votenum
testdat2$seatsh <- testdat2$x.y/testdat2$seatnum
testdat2$vosedis <- testdat2$seatsh-testdat2$votesh
socvote <- subset(testdat2, testdat2$Party =="SP")
socvote <- as.numeric(socvote["votesh"])
socvote <- ifelse(socvote %in% NA, 0, socvote)
testdat2$socvote <- rep(socvote,nrow(testdat2))
rightvot <- subset(testdat2,testdat2$Party !="SP")
rightvot <- ifelse(nrow(rightvot)==1 | nrow(rightvot)==0,1,max(rightvot$votesh)-sort(rightvot$votesh,partial=length(rightvot$votesh)-1)[length(rightvot$votesh)-1])
testdat2$rightvot <- rep(rightvot,nrow(testdat2))
testdat2 <- testdat2[c("Party","vosedis","socvote","rightvot","numpar")]
test2 <- merge(test,testdat2, by = "Party")
votsea[[i]] <- test2
}
votsea <- votsea[lapply(votsea,length)>0]
findat[[k]] <- rbind.fill(votsea)
}
findat <- findat[lapply(findat,length)>0]
fulldat[[j]] <- rbind.fill(findat)
}
fulldat <- fulldat[lapply(fulldat,length)>0]
elect <- rbind.fill(fulldat)
elect2 <- subset(elect, elect$Elected == 1)
data <- merge(elect2,vote2, by.x=c("name2","Vote_year"),by.y=c("Name","Year"))
andat <- subset(data, select = -c(Occupation,Eligible_Voters,Turnout,Praes,Frac,Unit,Potential_Vote,X) )
# Joint Lists
coal <- str_split_fixed(andat$Endorsed_by_other_Party, "#",4)
coalalt <- list()
for (i in 1:ncol(coal)){
coalalt[[i]] <-  ifelse(coal[,i] == "", NA, coal[,i])
}
coal <- data.frame(do.call(cbind, coalalt))
coal <- rename(coal, c("X1"="coal1", "X2"="coal2","X3"="coal3", "X4" = "coal4"))
coal$coal <- apply(coal,1, function(x) length(which(!is.na(x))))
coal$coalsp <- apply(coal,1, function(x) length(which(x =="SP")))
coal$coalnsp <- ifelse(coal$coalsp == 1, 0, coal$coal)
coal <- coal[c("coal","coalsp","coalnsp")]
andat <- cbind(andat,coal)
# Party Strength by Canton
streg <- read.csv2("D:/Sync/Dropbox/Papers/PR_NR_CH/Data/Party_Strength_by_Canton/Disprop_by_Canton.csv")
streg <- streg[with(streg, order(code, year)), ]
fin <- list()
for (i in unique(streg$code)){
dat <-  subset(streg, streg$code == i)
dis <- dat[c(9,12,13,15),]
colnames(dis) <- c("code","year","SP","Democrats","Radicals","Liberals","ER","KK")
final1 <- melt(dis, id.vars = c("code","year"), variable.name = "Party",value.name = "parst")
dis99 <- apply(dat[1:9,3:8],2,mean)
dis08 <- apply(dat[4:12,3:8],2,mean)
dis11 <- apply(dat[5:13,3:8],2,mean)
dis17 <- apply(dat[7:15,3:8],2,mean)
disfin <- data.frame(rep(unique(dat$code),4),c(1899,1908,1911,1917),rbind(t(dis99),t(dis08),t(dis11),t(dis17)))
colnames(disfin) <- c("code","year","SP","Democrats","Radicals","Liberals","ER","KK")
final2 <- melt(disfin, id.vars = c("code","year"), variable.name = "Party",value.name = "parst15")
final <- merge(final1,final2, by = c("code","year","Party"))
fin[[i]] <- final
}
parst <- rbind.fill(fin)
parst$year[parst$year == 1899] <- 1900
parst$year[parst$year == 1908] <- 1910
parst$year[parst$year == 1911] <- 1914
parst$year[parst$year == 1917] <- 1918
parst2 <- parst[parst$Party == "SP", ]
colnames(parst2) <- c("code","year","Party","socvote2","scovote15")
parst2 <- subset(parst2, select = -Party)
seats99 <- data.frame(unique(parst$code),rep(1900,25),c(10,1,3,27,3,4,6,5,2,5,7,5,1,1,11,2,4,3,5,6,1,12,5,1,17))
colnames(seats99) <- c("code","year","seats")
seats08 <- data.frame(unique(parst$code),rep(1910,25),c(10,1,3,29,3,6,6,7,2,5,7,6,1,1,13,2,5,3,6,6,1,14,6,1,22))
colnames(seats08) <- c("code","year","seats")
seats11 <- data.frame(unique(parst$code),rep(1914,25),c(12,1,3,32,4,7,7,8,2,6,8,7,1,1,15,2,6,3,7,8,1,16,6,1,25))
colnames(seats11) <- c("code","year","seats")
seats17 <- data.frame(unique(parst$code),rep(1918,25),c(12,1,3,32,4,7,7,8,2,6,8,7,1,1,15,2,6,3,7,8,1,16,6,1,25))
colnames(seats17) <- c("code","year","seats")
seats <- rbind(seats99,seats08,seats11,seats17)
data2 <- merge(parst,seats, by = c("code","year"))
# Seat share by Canton
tedat <- subset(elect,elect$Year == 1899 | elect$Year == 1908 | elect$Year == 1911 | elect$Year == 1912 |
elect$Year == 1913 |elect$Year == 1914 |elect$Year == 1917 | elect$Year == 1918)
tedat <- tedat[c("Canton","Year","Party","Elected")]
tedat$Year[tedat$Year < 1901] <- 1900
tedat$Year[tedat$Year < 1911 & tedat$Year > 1906] <- 1910
tedat$Year[tedat$Year < 1915 & tedat$Year > 1910] <- 1914
tedat$Year[tedat$Year > 1916] <- 1918
elected <- aggregate(tedat$Elected, list(Canton = tedat$Canton,Year = tedat$Year, Party = tedat$Party), sum)
colnames(elected)[4] <- "Elected"
data3 <- merge(data2,elected, by.x = c("code","year","Party"), by.y = c("Canton","Year","Party"), all.x = T )
data3$Elected[is.na(data3$Elected)] <- 0
data3$seash <- data3$Elected/data3$seats
testt <- data3[c("code","year","seash")]
test <- aggregate(testt$seash, list(Canton = testt$code, year = testt$year), sum)
data3$dispro <- data3$seash-data3$parst/100
data3$dispro15 <- data3$seash-data3$parst15/100
andat <- merge(andat,data3, by.x = c("Canton","Vote_year","Party"), by.y = c("code","year","Party"), all.x = T)
andat <- merge(andat, parst2, by.x = c("Canton","Vote_year"), by.y = c("code","year"))
# Soci-Economic Data
soceco <- read.csv2("D:/Sync/Dropbox/Papers/PR_NR_CH/Data/Socio_Economic_Data/Socio_Economic.csv")
soceco <- soceco[1:150,]
soceco$Year[soceco$Year == 1920] <- 1918
soceco14 <- subset(soceco, Year==1918)
soceco$Year[soceco$Year == 1918] <- 1914
soceco <- rbind(soceco,soceco14)
andat <- merge(andat,soceco, by.x = c("Electoral_District_Number","Vote_year"), by.y = c("Electoral_District_num","Year"))
# Skills
skills <- read.csv2("D:/Sync/Dropbox/Papers/PR_NR_CH/Data/Skills/Skills.csv")
skills <- subset(skills, select = c(Canton,Vote_year,skillpop))
andat <- merge(andat,skills, by = c("Canton","Vote_year"))
View(andat)
View(andat)
