# PR Swiss Cantons Data
library(dplyr)
library(readstata13)
library(brglm)
library(multiwayvcov)
library(lmtest)
library(effects)
rm(list=ls())
source("D:/Sync/Dropbox/Papers/Canton_Exec_Data/Graphs/Gen_Data.R")
names(fints)[names(fints)=="Jahr"] <- "year"
# Dominant Party Weighting
fints$dom <- apply(fints[2:16], 1, function(x) max(x))
fints$herf <- apply(fints[2:16], 1, function(x) sum(x^2))
fints$dom <- ifelse(fints$FDP>=.5 | fints$Rad>=.5,1,0)
fints$dom <- ifelse(fints$CVP>=.5 ,2,fints$dom)
fints$dom <- ifelse(fints$Lib>=.5 | fints$Kon>=.5 ,3,fints$dom)
fints$Code <- as.factor(fints$Code)
fints <- fints %>%
group_by(Code, dom,cumsum(c(FALSE, diff(dom) < 0))) %>%
mutate(yepo = row_number()) %>% select(-`cumsum(c(FALSE, diff(dom) < 0))`)
View(fints)
fints <- fints %>% mutate(yepo = ifelse(dom==0,0,yepo))
View(fints)
pr <- read.dta13("D:/Sync/Dropbox/Papers/PR_Cantons/Data/Lutz_Data.dta")
dat <- merge(pr,fints, by.x = c("kann","jahr"), by.y = c("Code","year"))
dat <- dat %>% mutate(time = duration, time2 = duration^2, time3 = duration^3)
test <- brglm(onset~domtim+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
cluster.ids.h <- data.frame(i = dat$knr)
mwfunch <- function(x,cluster) {return(cluster.vcov(x, cluster= cluster.ids.h))}
test <- brglm(onset~yepo+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
test <- brglm(onset~yepo+leftparties+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
View(fints)
test <- brglm(onset~yepo*herf+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
test <- brglm(onset~yepo+herf+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
View(fints)
# PR Swiss Cantons Data
library(dplyr)
library(readstata13)
library(brglm)
library(multiwayvcov)
library(lmtest)
library(effects)
rm(list=ls())
source("D:/Sync/Dropbox/Papers/Canton_Exec_Data/Graphs/Gen_Data.R")
names(fints)[names(fints)=="Jahr"] <- "year"
# Dominant Party Weighting
fints$dommax <- apply(fints[2:16], 1, function(x) max(x))
fints$herf <- apply(fints[2:16], 1, function(x) sum(x^2))
fints$dom <- ifelse(fints$FDP>=.5 | fints$Rad>=.5,1,0)
fints$dom <- ifelse(fints$CVP>=.5 ,2,fints$dom)
fints$dom <- ifelse(fints$Lib>=.5 | fints$Kon>=.5 ,3,fints$dom)
fints$Code <- as.factor(fints$Code)
fints <- fints %>%
group_by(Code, dom,cumsum(c(FALSE, diff(dom) < 0))) %>%
mutate(yepo = row_number())
fints <- fints %>% mutate(yepo = ifelse(dom==0,0,yepo))
# PR and Event History Structure
pr <- read.dta13("D:/Sync/Dropbox/Papers/PR_Cantons/Data/Lutz_Data.dta")
dat <- merge(pr,fints, by.x = c("kann","jahr"), by.y = c("Code","year"))
dat <- dat %>% mutate(time = duration, time2 = duration^2, time3 = duration^3)
test <- brglm(onset~yepo+dommax+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
test <- brglm(onset~yepo*dommax+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
test <- brglm(onset~yepo+dommax+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
test <- brglm(onset~yepo+dommax+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
cluster.ids.h <- data.frame(i = dat$knr)
mwfunch <- function(x,cluster) {return(cluster.vcov(x, cluster= cluster.ids.h))}
plotf <- as.data.frame(effect("dommax", test, vcov=mwfunch,xlevels=list(domtim=seq(min(dat$domtim),max(dat$domtim),1)),typical = mean))
plot(plotf$dommax,plotf$fit)
lines(plotf$dommax,plotf$lower)
lines(plotf$dommax,plotf$upper)
hist(dat$dommax)
cluster.ids.h <- data.frame(i = dat$knr)
mwfunch <- function(x,cluster) {return(cluster.vcov(x, cluster= cluster.ids.h))}
plotf <- as.data.frame(effect("dommax", test, vcov=mwfunch,xlevels=list(dommax=seq(min(dat$dommax),max(dat$dommax),1)),typical = mean))
plot(plotf$dommax,plotf$fit)
lines(plotf$dommax,plotf$lower)
lines(plotf$dommax,plotf$upper)
hist(dat$dommax)
test <- brglm(onset~yepo+dommax+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
cluster.ids.h <- data.frame(i = dat$knr)
mwfunch <- function(x,cluster) {return(cluster.vcov(x, cluster= cluster.ids.h))}
plotf <- as.data.frame(effect("dommax", test, vcov=mwfunch,xlevels=list(dommax=seq(min(dat$dommax),max(dat$dommax),1)),typical = mean))
test <- brglm(onset~dommax+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
cluster.ids.h <- data.frame(i = dat$knr)
mwfunch <- function(x,cluster) {return(cluster.vcov(x, cluster= cluster.ids.h))}
plotf <- as.data.frame(effect("dommax", test, vcov=mwfunch,xlevels=list(dommax=seq(min(dat$dommax),max(dat$dommax),1)),typical = mean))
test <- brglm(onset~dommax+yepo+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
test <- brglm(onset~poly(dommax,2,raw=T)+yepo+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
test <- brglm(onset~poly(dommax,2,raw=T)+lingfrakt+bevlkerunglog+anteil2sektor+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
test <- brglm(onset~dommax+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
test <- brglm(onset~dommax+yepo+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
cluster.ids.h <- data.frame(i = dat$knr)
mwfunch <- function(x,cluster) {return(cluster.vcov(x, cluster= cluster.ids.h))}
plotf <- as.data.frame(effect("dommax", test, vcov=mwfunch,xlevels=list(dommax=seq(min(dat$dommax),max(dat$dommax),1)),typical = mean))
test <- brglm(onset~yepo+time+time2+time3, dat, family = binomial(logit))
coeftest(test, cluster.vcov(test, dat$knr) )
cluster.ids.h <- data.frame(i = dat$knr)
