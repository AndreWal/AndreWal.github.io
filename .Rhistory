# Long run effects via delta method, Comparision of IV and delta method results
dat2$konkoutint <- dat2$konk*dat2$konkmiou
estd3 <- plm(fdlogPCwelfare_r~logPCwelfare_r+konk+konkmiou+konkoutint+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2+as.factor(year) , dat2, model = "pooling")
delta1 <- rbind(deltaMethod(estd3, c("konk/logPCwelfare_r*(-1)"), vcov. = vcovBK(estd3, cluster = "time")),
deltaMethod(estd3, c("konkmiou/logPCwelfare_r*(-1)"), vcov. = vcovBK(estd3, cluster = "time")),
deltaMethod(estd3, c("konkoutint/logPCwelfare_r*(-1)"), vcov. = vcovBK(estd3, cluster = "time")),
deltaMethod(estd3, c("konkmigin/logPCwelfare_r"), vcov. = vcovBK(estd3, cluster = "time")))
delcoef <- as.matrix(estd3$coefficients)
delcoef[3:6,1] <- as.matrix(delta1[,1])
delstd <- as.matrix(sqrt(diag(vcovBK(estd3, cluster = "time"))))
delstd[3:6,1] <- as.matrix(delta1[,2])
dat2$konk0 <- ifelse(dat2$konkalt ==0,1,0)
dat2$konk1 <- ifelse(dat2$konkalt ==1,1,0)
dat2$konk2 <- ifelse(dat2$konkalt ==2,1,0)
dat2$konk3 <- ifelse(dat2$konkalt ==3,1,0)
dat2$konk4 <- ifelse(dat2$konkalt ==4,1,0)
dat2$konkoutint2 <- dat2$konk2*dat2$konkmiou
dat2$konkoutint3 <- dat2$konk3*dat2$konkmiou
dat2$konkoutint4 <- dat2$konk4*dat2$konkmiou
estd7 <- plm(fdlogPCwelfare_r~logPCwelfare_r+konkmiou+konk2+konk3+konk4+konkoutint2+konkoutint3+konkoutint4+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2+as.factor(year) , dat2, model = "pooling")
delta2 <- rbind(deltaMethod(estd7, c("konkmiou/logPCwelfare_r*(-1)"), vcov. = vcovBK(estd7, cluster = "time")),
deltaMethod(estd7, c("konk2/logPCwelfare_r*(-1)"), vcov. = vcovBK(estd7, cluster = "time")),
deltaMethod(estd7, c("konk3/logPCwelfare_r*(-1)"), vcov. = vcovBK(estd7, cluster = "time")),
deltaMethod(estd7, c("konk4/logPCwelfare_r*(-1)"), vcov. = vcovBK(estd7, cluster = "time")),
deltaMethod(estd7, c("konkoutint2/logPCwelfare_r*(-1)"), vcov. = vcovBK(estd7, cluster = "time")),
deltaMethod(estd7, c("konkoutint3/logPCwelfare_r*(-1)"), vcov. = vcovBK(estd7, cluster = "time")),
deltaMethod(estd7, c("konkoutint4/logPCwelfare_r*(-1)"), vcov. = vcovBK(estd7, cluster = "time")),
deltaMethod(estd7, c("konkmigin/logPCwelfare_r"), vcov. = vcovBK(estd7, cluster = "time")))
delcoef2 <- as.matrix(estd7$coefficients)
delcoef2[3:10,1] <- as.matrix(delta2[,1])
delstd2 <- as.matrix(sqrt(diag(vcovBK(estd7, cluster = "time"))))
delstd2[3:10,1] <- as.matrix(delta2[,2])
est6 <- plm(flogPCwelfare_r~fdlogPCwelfare_r+as.factor(year)+konk+konkmiou+konkoutint+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2 |
logPCwelfare_r+as.factor(year)+konk+konkmiou+konkoutint+konkmigin+shfor+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2
, dat2, model = "pooling")
cov6 <- as.matrix(sqrt(diag(vcovBK(est6, cluster = "time"))))
rownames(cov6) <- (row.names(est6$vcov))
est9 <- plm(flogPCwelfare_r~fdlogPCwelfare_r+as.factor(year)+konkmiou+konk2+konk3+konk4+konkoutint2+konkoutint3+konkoutint4+konkmigin+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2 |
logPCwelfare_r+as.factor(year)+konkmiou+konk2+konk3+konk4+konkoutint2+konkoutint3+konkoutint4+konkmigin+shfor+infmort+empl2nd+depratio+perc_urban+log_pop2+logPCfedsubs_ptr+sigperpop20_gini*numpar+left+dfs+dummy_prop+Mandbugref+spsoc2
, dat2, model = "pooling")
